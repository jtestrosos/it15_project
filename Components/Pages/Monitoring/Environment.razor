@page "/monitoring/environment"
@using production_system.Data
@using production_system.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@inject IWeatherService WeatherService
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject production_system.Services.FacilityFilterService FacilityFilter
@inject production_system.Services.FacilityAccessService FacilityAccess
@rendermode InteractiveServer

<PageTitle>NodeSync | Environment Monitor</PageTitle>

<production_system.Components.Shared.FacilitySelector OnFacilityChanged="HandleFacilityChanged" />

@if (isSuperAdmin && FacilityFilter.SelectedFacilityId == null)
{
    <div class="card border-0 shadow-sm overflow-hidden mb-4">
        <div class="card-body p-5 text-center">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width:80px;height:80px;background:rgba(143,0,255,0.05);">
                <i class="bi bi-geo-alt text-primary fs-1"></i>
            </div>
            <h3 class="fw-bold text-gray-800">Select a Facility</h3>
            <p class="text-muted mx-auto" style="max-width: 500px;">
                Please select a specific facility from the selector above to see real-time environmental data. 
                Monitoring is disabled in global view because temperature and humidity readings are location-specific.
            </p>
        </div>
    </div>
}
else
{
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Environment Monitor</h1>
        <p class="text-muted mb-0">Real-time temperature and humidity readings.</p>
    </div>
</div>

<div class="row g-4">
    @if (isLoading)
    {
        <div class="col-12 text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Fetching weather data...</p>
        </div>
    }
    else if (weatherData != null)
    {
        <div class="col-lg-4">
            <div class="environment-card @GetTempClass()">
                <div class="card-icon">
                    <i class="bi bi-thermometer-half"></i>
                </div>
                <div class="card-content">
                    <span class="card-label">Temperature</span>
                    <span class="card-value">@weatherData.Temperature.ToString("F1")°C</span>
                    <span class="card-sublabel">Feels like @weatherData.FeelsLike.ToString("F1")°C</span>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="environment-card @GetHumidityClass()">
                <div class="card-icon">
                    <i class="bi bi-droplet-half"></i>
                </div>
                <div class="card-content">
                    <span class="card-label">Humidity</span>
                    <span class="card-value">@weatherData.Humidity%</span>
                    <span class="card-sublabel">Pressure: @weatherData.Pressure hPa</span>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="environment-card status-card @GetStatusClass()">
                <div class="card-icon">
                    <i class="bi @GetStatusIcon()"></i>
                </div>
                <div class="card-content">
                    <span class="card-label">Alert Status</span>
                    <span class="card-value">@weatherData.GetAlertStatus()</span>
                    <span class="card-sublabel">@weatherData.GetAlertSubtitle()</span>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-3">
                            <img src="@weatherData.IconUrl" alt="Weather" class="weather-icon" />
                            <div>
                                <h4 class="mb-1">@weatherData.Location, @weatherData.Country</h4>
                                <p class="mb-0 text-muted text-capitalize">@weatherData.Description</p>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-primary text-nowrap" @onclick="RefreshWeather" disabled="@isLoading">
                                <i class="bi bi-arrow-clockwise me-2"></i>Refresh
                            </button>
                            <button class="btn btn-outline-primary text-nowrap" @onclick="LogReading" disabled="@isLoading">
                                <i class="bi bi-database-add me-2"></i>Log Reading
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div class="col-12">
                <div class="alert @(statusMessage.Contains("Error") ? "alert-danger" : "alert-success") alert-dismissible fade show">
                    @statusMessage
                    <button type="button" class="btn-close" @onclick="@(() => statusMessage = "")"></button>
                </div>
            </div>
        }

        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-clock-history me-1"></i> Recent Readings</span>
                    <span class="badge bg-light text-dark border">@recentReadings.Count reading(s)</span>
                </div>
                <div class="card-body">
                    @if (recentReadings.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>Date/Time</th>
                                        <th>Temperature</th>
                                        <th>Humidity</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var reading in recentReadings)
                                    {
                                        <tr>
                                            <td>@reading.RecordedDate.ToString("MMM dd, yyyy HH:mm")</td>
                                            <td>@reading.Temperature.ToString("F1")°C</td>
                                            <td>@reading.Humidity%</td>
                                            <td>
                                                <span class="badge @GetBadgeClass(reading.AlertStatus)">@reading.AlertStatus</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-3 mb-0">No readings logged yet. Click "Log Reading" to save the current data.</p>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle me-2"></i>
                Unable to fetch weather data. Please check your internet connection and try again.
                <button class="btn btn-sm btn-warning ms-3" @onclick="RefreshWeather">Retry</button>
            </div>
        </div>
    }
</div>
}

<style>
    .environment-card {
        background: linear-gradient(135deg, #8F00FF 0%, #7C3AED 100%);
        border-radius: 0.75rem;
        padding: 1.5rem;
        color: white;
        display: flex;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 4px 12px rgba(143, 0, 255, 0.2);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .environment-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(143, 0, 255, 0.3);
    }

    .temp-optimal {
        background: linear-gradient(135deg, #EA580C 0%, #F97316 100%); /* Orange */
        box-shadow: 0 4px 12px rgba(234, 88, 12, 0.3);
    }
    
    .temp-warning {
        background: linear-gradient(135deg, #EA580C 0%, #F97316 100%); /* Amber */
        box-shadow: 0 4px 12px rgba(234, 88, 12, 0.3);
    }
    
    .temp-critical {
        background: linear-gradient(135deg, #D10000 0%, #EF4444 100%); /* Red */
        box-shadow: 0 4px 12px rgba(209, 0, 0, 0.3);
    }
    
    .temp-cold {
        background: linear-gradient(135deg, #0062FF 0%, #3B82F6 100%); /* Blue */
        box-shadow: 0 4px 12px rgba(0, 98, 255, 0.3);
    }

    .humidity-optimal {
        background: linear-gradient(135deg, #059669 0%, #10B981 100%); /* Green */
        box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
    }

    .humidity-risk {
        background: linear-gradient(135deg, #EA580C 0%, #F97316 100%); /* Amber/Yellow Drop */
        box-shadow: 0 4px 12px rgba(234, 88, 12, 0.3);
    }

    .status-card.status-normal {
        background: linear-gradient(135deg, #059669 0%, #10B981 100%);
        box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
    }

    .status-card.status-warning {
        background: linear-gradient(135deg, #EA580C 0%, #F97316 100%);
        box-shadow: 0 4px 12px rgba(234, 88, 12, 0.3);
    }

    .status-card.status-critical {
        background: linear-gradient(135deg, #D10000 0%, #EF4444 100%);
        box-shadow: 0 4px 12px rgba(209, 0, 0, 0.3);
    }

    .card-icon {
        width: 60px;
        height: 60px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
    }

    .card-content {
        display: flex;
        flex-direction: column;
    }

    .card-label {
        font-size: 0.875rem;
        opacity: 0.9;
    }

    .card-value {
        font-size: 2rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .card-sublabel {
        font-size: 0.75rem;
        opacity: 0.8;
    }

    .weather-icon {
        width: 64px;
        height: 64px;
    }
</style>

@code {
    private WeatherData? weatherData;
    private bool isLoading = true;
    private string statusMessage = "";
    private List<production_system.Models.EnvironmentalMonitor> recentReadings = new();
    private int? userFacilityId;
    private bool isSuperAdmin;
    private string currentLocation = "";
    private string currentApiKey = "";

    private int? GetEffectiveFacilityId()
    {
        if (isSuperAdmin)
            return FacilityFilter.SelectedFacilityId;
        return userFacilityId;
    }

    private async Task HandleFacilityChanged()
    {
        await LoadFacilityLocation();
        await RefreshWeather();
        await LoadRecentReadings();
    }

    protected override async Task OnInitializedAsync()
    {
        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();
        
        await LoadFacilityLocation();
        await RefreshWeather();
        await LoadRecentReadings();
    }

    private async Task LoadFacilityLocation()
    {
        currentLocation = "";
        currentApiKey = "";

        var effectiveFacilityId = GetEffectiveFacilityId();
        if (effectiveFacilityId.HasValue)
        {
            using var scope = ScopeFactory.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
            var facility = await context.Facilities.FindAsync(effectiveFacilityId.Value);

            if (facility != null)
            {
                currentLocation = facility.Location ?? "";
                currentApiKey = facility.APIKeyOpenWeather ?? "";
            }
        }
    }

    private async Task RefreshWeather()
    {
        isLoading = true;
        StateHasChanged();

        weatherData = await WeatherService.GetCurrentWeatherAsync(currentLocation, currentApiKey);
        
        isLoading = false;
        StateHasChanged();
    }

    private async Task LogReading()
    {
        if (weatherData == null) return;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            
            using var scope = ScopeFactory.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
            
            var user = await context.Users
                .Where(u => u.Id == userId)
                .FirstOrDefaultAsync();

            var effectiveFacilityId = GetEffectiveFacilityId();

            var reading = new production_system.Models.EnvironmentalMonitor
            {
                FacilityID = effectiveFacilityId ?? 1,
                Temperature = weatherData.Temperature,
                Humidity = weatherData.Humidity,
                RecordedDate = DateTime.Now,
                AlertStatus = weatherData.GetAlertStatus()
            };

            context.EnvironmentalMonitors.Add(reading);
            await context.SaveChangesAsync();
            
            statusMessage = "Reading logged successfully!";
            await LoadRecentReadings();
        }
        catch (Exception ex)
        {
            statusMessage = $"Error logging reading: {ex.Message}";
        }
    }

    private async Task LoadRecentReadings()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var query = context.EnvironmentalMonitors.AsQueryable();
        
        // The user's facility is already loaded in LoadFacilityLocation
        // Filter by facility faor non-superadmin users
        var effectiveFacilityId = GetEffectiveFacilityId();
        if (effectiveFacilityId.HasValue)
        {
            query = query.Where(r => r.FacilityID == effectiveFacilityId.Value);
        }
        
        recentReadings = await query
            .OrderByDescending(r => r.RecordedDate)
            .Take(10)
            .ToListAsync();
    }

    private string GetStatusClass() => weatherData?.GetAlertStatus() switch
    {
        "Critical" => "status-critical",
        "Warning" or "Cold Warning" or "High Humidity" => "status-warning",
        _ => "status-normal"
    };

    private string GetStatusIcon() => weatherData?.GetAlertStatus() switch
    {
        "Critical" => "bi-exclamation-triangle-fill",
        "Warning" or "Cold Warning" or "High Humidity" => "bi-exclamation-circle-fill",
        _ => "bi-check-circle-fill"
    };

    private string GetBadgeClass(string status) => status switch
    {
        "Critical" => "bg-danger",
        "Warning" or "Cold Warning" or "High Humidity" => "bg-warning text-dark",
        _ => "bg-success"
    };

    private string GetTempClass()
    {
        if (weatherData == null) return "temp-optimal";
        if (weatherData.Temperature > 40) return "temp-critical";
        if (weatherData.Temperature > 35) return "temp-warning";
        if (weatherData.Temperature < 10) return "temp-cold";
        return "temp-optimal";
    }

    private string GetHumidityClass()
    {
        if (weatherData == null) return "humidity-optimal";
        if (weatherData.Humidity >= 40 && weatherData.Humidity <= 60) return "humidity-optimal";
        return "humidity-risk";
    }
}

