@page "/production/workorders"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@using production_system.Data
@using production_system.Models

@attribute [Authorize(Roles = "ProductionManager,Superadmin")]
@inject IServiceScopeFactory ScopeFactory
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>NodeSync | Work Orders</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Work Orders</h1>
        <p class="text-muted mb-0">Assign production tasks to workers.</p>
    </div>
    <div class="d-flex flex-column gap-2 align-items-end">
        <button class="btn btn-outline-secondary" @onclick="ToggleArchivedView">
            <i class="bi @(ShowArchived ? "bi-eye-slash" : "bi-archive") me-1"></i>
            @(ShowArchived ? "Show Active" : "Show Archived")
        </button>
        <button class="btn btn-primary" @onclick="OpenCreateModal" disabled="@ShowArchived">
            <i class="bi bi-plus-lg me-1"></i> New Work Order
        </button>
    </div>
</div>

@if (ShowCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create Work Order</h5>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="NewOrder" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Production Plan</label>
                            <InputSelect class="form-select" @bind-Value="NewOrder.PlanID">
                                <option value="0">Select Plan</option>
                                @foreach (var p in plans)
                                {
                                    <option value="@p.PlanID">#@p.PlanID - @p.Product?.ProductName (@p.BatchQuantity)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Assign To Worker</label>
                            <InputSelect class="form-select" @bind-Value="NewOrder.UserID">
                                <option value="">Select Worker</option>
                                @foreach (var w in workers)
                                {
                                    <option value="@w.Id">@w.UserName</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputText class="form-control" @bind-Value="NewOrder.OrderDescription" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Batch Quantity</label>
                            <InputNumber class="form-control" @bind-Value="NewOrder.BatchQuantity" />
                        </div>
                        
                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseCreateModal">Cancel</button>
                             <button type="submit" class="btn btn-primary">Create Order</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (orders == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading work orders...</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-list-task me-1"></i>
                @(ShowArchived ? "Archived Work Orders" : "Active Work Orders")
            </span>
            <span class="badge bg-light text-dark border">@orders.Count item(s)</span>
        </div>
        <div class="card-body p-0">
            @if (!orders.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2" style="opacity: 0.3;"></i>
                    @if (ShowArchived)
                    {
                        <p>No archived work orders.</p>
                    }
                    else
                    {
                        <p>No active work orders yet. Click <strong>New Work Order</strong> to create one.</p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Description</th>
                                <th>Product</th>
                                <th>Worker</th>
                                <th>Status</th>
                                <th>Progress</th>
                                <th class="text-center" style="width: 120px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in orders)
                            {
                                <tr class="@(IsArchivedStatus(order.Status) ? "table-light text-muted" : "")">
                                    <td class="ps-4 text-muted small">#@order.OrderID</td>
                                    <td class="fw-bold">@order.OrderDescription</td>
                                    <td>@order.Plan?.Product?.ProductName</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="bi bi-person me-1"></i> @order.User?.UserName
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @GetStatusBadge(order.Status)">@order.Status</span>
                                    </td>
                                    <td>
                                        @if(order.Status == "Completed")
                                        {
                                            <div class="progress" style="height: 6px; width: 100px;">
                                                <div class="progress-bar bg-success" role="progressbar" style="width: 100%"></div>
                                            </div>
                                        }
                                        else if (order.Status == "In Progress")
                                        {
                                            <div class="progress" style="height: 6px; width: 100px;">
                                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width: 50%"></div>
                                            </div>
                                        }
                                        else if (order.Status == "Failed" || order.Status == "Canceled")
                                        {
                                            <div class="progress" style="height: 6px; width: 100px;">
                                                <div class="progress-bar bg-danger" role="progressbar" style="width: 100%"></div>
                                            </div>
                                        }
                                        else 
                                        {
                                            <div class="progress" style="height: 6px; width: 100px;">
                                                <div class="progress-bar" role="progressbar" style="width: 0%"></div>
                                            </div>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (!IsArchivedStatus(order.Status))
                                        {
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => ArchiveOrder(order)" title="Archive">
                                                <i class="bi bi-archive"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => RestoreOrder(order)" title="Restore">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<WorkOrder>? orders;
    private List<ProductionPlan> plans = new();
    private IList<ApplicationUser> workers = new List<ApplicationUser>();
    private bool ShowCreateModal = false;
    private bool ShowArchived = false;
    private WorkOrder NewOrder = new();
    private int? userFacilityId;
    private bool isSuperAdmin;
    private string? currentUserId;

    private static readonly string[] ArchivedStatuses = { "Completed", "Canceled", "Failed" };

    [Inject] private production_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();
        currentUserId = await FacilityAccess.GetCurrentUserIdAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var planQuery = context.ProductionPlans.Include(p => p.Product).Where(p => p.Status == "Active" || p.Status == "Draft").AsQueryable();
        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            planQuery = planQuery.Where(p => p.FacilityID == userFacilityId.Value);
        }
        plans = await planQuery.ToListAsync();

        // Filter workers by facility
        var allWorkers = await UserManager.GetUsersInRoleAsync("ProductionWorker");
        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            workers = allWorkers.Where(w => w.FacilityID == userFacilityId.Value).ToList();
        }
        else
        {
            workers = allWorkers;
        }

        var orderQuery = context.WorkOrders
            .Include(o => o.Plan)
            .ThenInclude(p => p.Product)
            .Include(o => o.User)
            .OrderByDescending(o => o.OrderID)
            .AsQueryable();

        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            orderQuery = orderQuery.Where(o => o.FacilityID == userFacilityId.Value);
        }

        if (ShowArchived)
        {
            orderQuery = orderQuery.Where(o => ArchivedStatuses.Contains(o.Status));
        }
        else
        {
            orderQuery = orderQuery.Where(o => !ArchivedStatuses.Contains(o.Status));
        }

        orders = await orderQuery.ToListAsync();
    }

    private async Task ToggleArchivedView()
    {
        ShowArchived = !ShowArchived;
        await LoadData();
    }

    private bool IsArchivedStatus(string status) => ArchivedStatuses.Contains(status);

    private void OpenCreateModal()
    {
        NewOrder = new WorkOrder { Status = "Pending" };
        ShowCreateModal = true;
    }

    private void CloseCreateModal()
    {
        ShowCreateModal = false;
    }

    private async Task HandleValidSubmit()
    {
        if (NewOrder.PlanID == 0 || string.IsNullOrEmpty(NewOrder.UserID)) return;

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        NewOrder.FacilityID = userFacilityId;
        context.WorkOrders.Add(NewOrder);
        await context.SaveChangesAsync();
        
        var log = new production_system.Models.ActivityLog
        {
            UserID = currentUserId ?? "",
            ActionType = "Create Work Order",
            Details = $"Created new Work Order for Plan #{NewOrder.PlanID}",
            Timestamp = DateTime.Now,
            FacilityID = userFacilityId
        };
        context.ActivityLogs.Add(log);

        var notification = new production_system.Models.SystemNotification
        {
            FacilityID = userFacilityId,
            UserID = NewOrder.UserID,
            Title = $"New Task Assigned: #{NewOrder.OrderID}",
            Message = $"You've been assigned a new task: \"{NewOrder.OrderDescription}\".",
            Category = "WorkOrder",
            Severity = "Info",
            LinkUrl = "/tasks/assigned",
            CreatedAt = DateTime.UtcNow
        };
        context.SystemNotifications.Add(notification);

        await context.SaveChangesAsync();

        await LoadData();
        CloseCreateModal();
    }

    private async Task ArchiveOrder(WorkOrder order)
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var dbOrder = await context.WorkOrders.FindAsync(order.OrderID);
        if (dbOrder != null)
        {
            dbOrder.Status = "Canceled";
            
            var log = new production_system.Models.ActivityLog
            {
                UserID = currentUserId ?? "",
                ActionType = "Archive Work Order",
                Details = $"Archived Work Order #{order.OrderID}",
                Timestamp = DateTime.Now,
                FacilityID = userFacilityId
            };
            context.ActivityLogs.Add(log);

            await context.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task RestoreOrder(WorkOrder order)
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var dbOrder = await context.WorkOrders.FindAsync(order.OrderID);
        if (dbOrder != null)
        {
            dbOrder.Status = "Pending";
            
            var log = new production_system.Models.ActivityLog
            {
                UserID = currentUserId ?? "",
                ActionType = "Restore Work Order",
                Details = $"Restored Work Order #{order.OrderID}",
                Timestamp = DateTime.Now,
                FacilityID = userFacilityId
            };
            context.ActivityLogs.Add(log);

            await context.SaveChangesAsync();
            await LoadData();
        }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Completed" => "bg-success",
        "In Progress" => "bg-primary",
        "Pending" => "bg-warning text-dark",
        "Canceled" => "bg-danger",
        "Failed" => "bg-danger",
        _ => "bg-light text-dark border"
    };
}

