@page "/production/costs"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using production_system.Data
@using production_system.Models
@using production_system.Services

@attribute [Authorize(Roles = "ProductionManager,Superadmin")]
@inject IServiceScopeFactory ScopeFactory
@inject IExchangeRateService ExchangeRateService
@inject production_system.Services.FacilityFilterService FacilityFilter

<PageTitle>NodeSync | Production Costs</PageTitle>

<production_system.Components.Shared.FacilitySelector OnFacilityChanged="HandleFacilityChanged" />

@if (isSuperAdmin && FacilityFilter.SelectedFacilityId == null)
{
    <div class="card border-0 shadow-sm overflow-hidden mb-4">
        <div class="card-body p-5 text-center">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width:80px;height:80px;background:rgba(143,0,255,0.05);">
                <i class="bi bi-geo-alt text-primary fs-1"></i>
            </div>
            <h3 class="fw-bold text-gray-800">Select a Facility</h3>
            <p class="text-muted mx-auto" style="max-width: 500px;">
                Please select a specific facility from the selector above to track material and labor expenses. 
                Global cost viewing is disabled to ensure accurate currency conversion and API key integration for each site.
            </p>
        </div>
    </div>
}
else
{
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Production Costs</h1>
        <p class="text-muted mb-0">Track material and labor expenses with live currency conversion.</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-primary" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg me-1"></i> Record Cost
        </button>
    </div>
</div>

@if (!isRatesLoading && exchangeRates == null)
{
    <div class="alert alert-warning mb-4">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Unable to fetch exchange rate data. Please check your API key configuration or network connection.
        <button class="btn btn-sm btn-warning ms-3" @onclick="RefreshRates">Retry</button>
    </div>
}

<!-- Exchange Rate Card -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:rgba(143,0,255,0.1);">
                    <i class="bi bi-currency-exchange text-primary fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">USD &rarr; PHP Rate</div>
                    <div class="fw-bold fs-5">
                        @if (isRatesLoading)
                        {
                            <span class="text-muted">Loading...</span>
                        }
                        else if (exchangeRates != null)
                        {
                            <span>&#8369;@exchangeRates.PhpRate.ToString("N4")</span>
                        }
                        else
                        {
                            <span class="text-danger">Unavailable</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:rgba(86, 174, 87,0.1);">
                    <i class="bi bi-graph-up-arrow text-success fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Costs (PHP)</div>
                    <div class="fw-bold fs-5">&#8369;@totalCostPhp.ToString("N2")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background:rgba(255, 150, 79,0.1);">
                    <i class="bi bi-clock-history text-warning fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Last Rate Update</div>
                    <div class="fw-bold">
                        @if (isRatesLoading)
                        {
                            <span class="text-muted">Loading...</span>
                        }
                        else if (exchangeRates != null)
                        {
                            @exchangeRates.LastUpdated.ToLocalTime().ToString("g")
                        }
                        else
                        {
                            <span class="text-muted">&mdash;</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (ShowCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Record New Cost</h5>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="NewCost" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Related Work Order</label>
                            <InputSelect class="form-select" @bind-Value="NewCost.OrderID">
                                <option value="">General / Overhead</option>
                                @foreach (var o in orders)
                                {
                                    <option value="@o.OrderID">Order #@o.OrderID - @o.OrderDescription</option>
                                }
                            </InputSelect>
                        </div>
                         <div class="mb-3">
                            <label class="form-label">Related Component (Optional)</label>
                            <InputSelect class="form-select" @bind-Value="NewCost.ComponentID">
                                <option value="">None</option>
                                @foreach (var c in components)
                                {
                                    <option value="@c.ComponentID">@c.ComponentName (@c.CurrencyCode)</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Cost Type</label>
                            <InputSelect class="form-select" @bind-Value="NewCost.CostType">
                                <option value="Material">Material</option>
                                <option value="Labor">Labor</option>
                                <option value="Overhead">Overhead</option>
                            </InputSelect>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Amount (PHP)</label>
                                <InputNumber class="form-control" @bind-Value="NewCost.Amount" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Currency Rate (from API)</label>
                                <InputNumber class="form-control bg-light" @bind-Value="NewCost.CurrencyRate" readonly />
                                <div class="form-text">
                                    @if (exchangeRates != null)
                                    {
                                        <span class="text-success">Live: 1 USD = &#8369;@exchangeRates.PhpRate.ToString("N4")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">API unavailable â€” using default fallback</span>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseCreateModal">Cancel</button>
                             <button type="submit" class="btn btn-primary">Save Record</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (costs == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading cost records...</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-currency-exchange me-1"></i> Cost Records</span>
            <span class="badge bg-light text-dark border">@costs.Count record(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Date</th>
                            <th>Type</th>
                            <th>Reference</th>
                            <th>Amount (PHP)</th>
                            <th>Rate</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cost in costs)
                        {
                            <tr>
                                <td class="ps-4">@cost.RecordedDate.ToShortDateString()</td>
                                <td>
                                    <span class="badge @GetCostTypeBadge(cost.CostType)">@cost.CostType</span>
                                </td>
                                <td class="text-muted small">
                                    @if(cost.OrderID != null) { <span>Order #@cost.OrderID</span> }
                                    @if(cost.ComponentID != null) { <span> | @cost.Component?.ComponentName</span> }
                                </td>
                                <td class="fw-bold">&#8369;@cost.Amount.ToString("N2")</td>
                                <td class="text-muted small">@cost.CurrencyRate</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
}

@code {
    private List<Cost>? costs;
    private List<WorkOrder> orders = new();
    private List<Component> components = new();
    private bool ShowCreateModal = false;
    private Cost NewCost = new();
    private int? userFacilityId;
    private bool isSuperAdmin;
    private ExchangeRateData? exchangeRates;
    private decimal totalCostPhp = 0;
    private bool isRatesLoading = true;

    [Inject] private production_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    private int? GetEffectiveFacilityId()
    {
        if (isSuperAdmin)
            return FacilityFilter.SelectedFacilityId;
        return userFacilityId;
    }

    private async Task HandleFacilityChanged()
    {
        await RefreshRates();
        await LoadData();
    }

    protected override async Task OnInitializedAsync()
    {
        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();
        
        await RefreshRates();
        await LoadData();
    }

    private async Task RefreshRates()
    {
        isRatesLoading = true;
        string apiKey = "";
        
        var effectiveFacilityId = GetEffectiveFacilityId();

        if (effectiveFacilityId.HasValue)
        {
            using var scope = ScopeFactory.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
            var facility = await context.Facilities.FindAsync(effectiveFacilityId.Value);
            apiKey = facility?.APIKeyExchangeRate ?? "";
        }

        // Fetch live exchange rates from API
        try
        {
            exchangeRates = await ExchangeRateService.GetExchangeRatesAsync(apiKey, "USD");
        }
        catch
        {
            exchangeRates = null;
        }
        
        isRatesLoading = false;
    }

    private async Task LoadData()
    {
        var effectiveFacilityId = GetEffectiveFacilityId();

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var orderQuery = context.WorkOrders.OrderByDescending(o => o.OrderID).AsQueryable();
        if (effectiveFacilityId.HasValue)
        {
            orderQuery = orderQuery.Where(o => o.FacilityID == effectiveFacilityId.Value);
        }
        orders = await orderQuery.ToListAsync();

        var componentQuery = context.Components.Where(c => !c.IsArchived).AsQueryable();
        if (effectiveFacilityId.HasValue)
        {
            componentQuery = componentQuery.Where(c => c.FacilityID == effectiveFacilityId.Value);
        }
        components = await componentQuery.ToListAsync();

        var costQuery = context.Costs
            .Include(c => c.Order)
            .Include(c => c.Component)
            .OrderByDescending(c => c.RecordedDate)
            .AsQueryable();

        if (effectiveFacilityId.HasValue)
        {
            costQuery = costQuery.Where(c => c.FacilityID == effectiveFacilityId.Value);
        }

        costs = await costQuery.ToListAsync();
        totalCostPhp = costs.Sum(c => c.Amount);
    }

    private void OpenCreateModal()
    {
        NewCost = new Cost 
        { 
            RecordedDate = DateTime.Now,
            CurrencyRate = exchangeRates?.PhpRate ?? 1.0m,
            CostType = "Material"
        };
        ShowCreateModal = true;
    }

    private void CloseCreateModal()
    {
        ShowCreateModal = false;
    }

    private async Task HandleValidSubmit()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        NewCost.FacilityID = GetEffectiveFacilityId() ?? userFacilityId;
        context.Costs.Add(NewCost);
        await context.SaveChangesAsync();
        await LoadData();
        CloseCreateModal();
    }

    private string GetCostTypeBadge(string type) => type switch
    {
        "Material" => "bg-primary",
        "Labor" => "bg-info text-dark",
        "Overhead" => "bg-warning text-dark",
        _ => "bg-secondary"
    };
}

