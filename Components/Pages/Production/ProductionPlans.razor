@page "/production/plans"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using production_system.Data
@using production_system.Models

@attribute [Authorize(Roles = "ProductionManager,Superadmin")]
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>NodeSync | Production Plans</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Production Plans</h1>
        <p class="text-muted mb-0">Plan manufacturing batches.</p>
    </div>
    <div class="d-flex flex-column gap-2 align-items-end">
        <button class="btn btn-outline-secondary" @onclick="ToggleArchivedView">
            <i class="bi @(ShowArchived ? "bi-eye-slash" : "bi-archive") me-1"></i>
            @(ShowArchived ? "Show Active" : "Show Archived")
        </button>
        <button class="btn btn-primary" @onclick="OpenCreateModal" disabled="@ShowArchived">
            <i class="bi bi-plus-lg me-1"></i> New Plan
        </button>
    </div>
</div>

@if (ShowCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(IsEditing ? "Edit Production Plan" : "Create Production Plan")</h5>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="NewPlan" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Product to Build</label>
                            <InputSelect class="form-select" @bind-Value="NewPlan.ProductID">
                                <option value="0">Select Product</option>
                                @foreach (var p in products)
                                {
                                    <option value="@p.ProductID">@p.ProductName</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Quantity</label>
                            <InputNumber class="form-control" @bind-Value="NewPlan.BatchQuantity" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Start Date</label>
                                <InputDate class="form-control" @bind-Value="NewPlan.PlannedStartDate" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">End Date</label>
                                <InputDate class="form-control" @bind-Value="NewPlan.PlannedEndDate" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                             <InputSelect class="form-select" @bind-Value="NewPlan.Status">
                                <option value="Draft">Draft</option>
                                <option value="Active">Active</option>
                            </InputSelect>
                        </div>
                        
                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseCreateModal">Cancel</button>
                             <button type="submit" class="btn btn-primary">@(IsEditing ? "Save Changes" : "Create Plan")</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (plans == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading plans...</p>
    </div>
}
else if (!plans.Any())
{
    <div class="card mb-4">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-inbox fs-1 d-block mb-2" style="opacity: 0.3;"></i>
            @if (ShowArchived)
            {
                <p>No archived or canceled plans.</p>
            }
            else
            {
                <p>No active plans yet. Click <strong>New Plan</strong> to create one.</p>
            }
        </div>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-calendar2-week me-1"></i>
                @(ShowArchived ? "Archived / Canceled Plans" : "Active Plans")
            </span>
            <span class="badge bg-light text-dark border">@plans.Count plan(s)</span>
        </div>
        <div class="card-body">
            <div class="row g-4">
                @foreach (var plan in plans)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="card h-100 shadow-sm border-0 border-start border-4 @GetStatusBorder(plan.Status)">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                     <h5 class="card-title fw-bold mb-0">@plan.Product?.ProductName</h5>
                                     <span class="badge @GetStatusBadge(plan.Status)">@plan.Status</span>
                                </div>
                                <p class="text-muted small mb-3">#@plan.PlanID created by @plan.User?.UserName</p>
                                
                                <div class="d-flex justify-content-between mb-2">
                                    <span><i class="bi bi-boxes me-1 text-muted"></i> Quantity:</span>
                                    <span class="fw-bold">@plan.BatchQuantity</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                     <span><i class="bi bi-calendar-event me-1 text-muted"></i> Start:</span>
                                     <span>@plan.PlannedStartDate.ToShortDateString()</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                     <span><i class="bi bi-calendar-check me-1 text-muted"></i> End:</span>
                                     <span>@plan.PlannedEndDate.ToShortDateString()</span>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 pb-3 pt-0 text-end">
                                @if (plan.Status != "Archived" && plan.Status != "Canceled")
                                {
                                    <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => OpenEditModal(plan)" title="Edit">
                                        <i class="bi bi-pencil me-1"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => ArchivePlan(plan)" title="Archive">
                                        <i class="bi bi-archive me-1"></i> Archive
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-success" @onclick="() => RestorePlan(plan)" title="Restore to Draft">
                                        <i class="bi bi-arrow-counterclockwise me-1"></i> Restore
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<ProductionPlan>? plans;
    private List<Product> products = new();
    private bool ShowCreateModal = false;
    private bool IsEditing = false;
    private bool ShowArchived = false;
    private ProductionPlan NewPlan = new();
    private string? currentUserId;
    private int? userFacilityId;
    private bool isSuperAdmin;

    [Inject] private production_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();

        await LoadData();
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var productQuery = context.Products.Where(p => !p.IsArchived).AsQueryable();
        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            productQuery = productQuery.Where(p => p.FacilityID == userFacilityId.Value);
        }
        products = await productQuery.ToListAsync();

        var planQuery = context.ProductionPlans
            .Include(p => p.Product)
            .Include(p => p.User)
            .OrderByDescending(p => p.PlanID)
            .AsQueryable();

        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            planQuery = planQuery.Where(p => p.FacilityID == userFacilityId.Value);
        }

        if (ShowArchived)
        {
            planQuery = planQuery.Where(p => p.Status == "Archived" || p.Status == "Canceled");
        }
        else
        {
            planQuery = planQuery.Where(p => p.Status != "Archived" && p.Status != "Canceled");
        }

        plans = await planQuery.ToListAsync();
    }

    private async Task ToggleArchivedView()
    {
        ShowArchived = !ShowArchived;
        await LoadData();
    }

    private void OpenCreateModal()
    {
        IsEditing = false;
        NewPlan = new ProductionPlan 
        { 
            PlannedStartDate = DateTime.Today,
            PlannedEndDate = DateTime.Today.AddDays(7),
            Status = "Draft"
        };
        ShowCreateModal = true;
    }

    private void OpenEditModal(ProductionPlan plan)
    {
        IsEditing = true;
        NewPlan = new ProductionPlan
        {
            PlanID = plan.PlanID,
            ProductID = plan.ProductID,
            BatchQuantity = plan.BatchQuantity,
            PlannedStartDate = plan.PlannedStartDate,
            PlannedEndDate = plan.PlannedEndDate,
            Status = plan.Status,
            UserID = plan.UserID,
            FacilityID = plan.FacilityID
        };
        ShowCreateModal = true;
    }

    private void CloseCreateModal()
    {
        ShowCreateModal = false;
    }

    private async Task HandleValidSubmit()
    {
        if (NewPlan.ProductID == 0 || string.IsNullOrEmpty(currentUserId)) return;

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        if (IsEditing)
        {
            var dbPlan = await context.ProductionPlans.FindAsync(NewPlan.PlanID);
            if (dbPlan != null)
            {
                dbPlan.ProductID = NewPlan.ProductID;
                dbPlan.BatchQuantity = NewPlan.BatchQuantity;
                dbPlan.PlannedStartDate = NewPlan.PlannedStartDate;
                dbPlan.PlannedEndDate = NewPlan.PlannedEndDate;
                dbPlan.Status = NewPlan.Status;
                
                var log = new production_system.Models.ActivityLog
                {
                    UserID = currentUserId,
                    ActionType = "Edit Production Plan",
                    Details = $"Edited Production Plan #{NewPlan.PlanID}",
                    Timestamp = DateTime.Now,
                    FacilityID = userFacilityId
                };
                context.ActivityLogs.Add(log);
            }
        }
        else
        {
            NewPlan.UserID = currentUserId;
            NewPlan.FacilityID = userFacilityId;
            context.ProductionPlans.Add(NewPlan);
            
            var log = new production_system.Models.ActivityLog
            {
                UserID = currentUserId,
                ActionType = "Create Production Plan",
                Details = $"Created Production Plan for Product #{NewPlan.ProductID}",
                Timestamp = DateTime.Now,
                FacilityID = userFacilityId
            };
            context.ActivityLogs.Add(log);
        }

        await context.SaveChangesAsync();
        await LoadData();
        CloseCreateModal();
    }

    private async Task ArchivePlan(ProductionPlan plan)
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var dbPlan = await context.ProductionPlans.FindAsync(plan.PlanID);
        if (dbPlan != null)
        {
            dbPlan.Status = "Archived";
            await context.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task RestorePlan(ProductionPlan plan)
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var dbPlan = await context.ProductionPlans.FindAsync(plan.PlanID);
        if (dbPlan != null)
        {
            dbPlan.Status = "Draft";
            await context.SaveChangesAsync();
            await LoadData();
        }
    }

    private string GetStatusBorder(string status) => status switch
    {
        "Completed" => "border-success",
        "Active" => "border-primary",
        "Draft" => "border-secondary",
        "Archived" => "border-warning",
        "Canceled" => "border-danger",
        _ => "border-primary"
    };

    private string GetStatusBadge(string status) => status switch
    {
        "Completed" => "bg-success",
        "Active" => "bg-primary",
        "Draft" => "bg-secondary",
        "Archived" => "bg-warning text-dark",
        "Canceled" => "bg-danger",
        _ => "bg-primary"
    };
}

