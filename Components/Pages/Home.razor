@page "/"
@using production_system.Data
@using production_system.Models
@using production_system.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@attribute [Authorize]
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IWeatherService WeatherService

<PageTitle>NodeSync | Dashboard</PageTitle>

<div class="page-header mb-4">
    <div class="row align-items-center">
        <div class="col-8">
            <h1 class="display-6 fw-800 mb-1">Operational Dashboard</h1>
            <p class="text-muted mb-0">NodeSync Integrated Production & Logistics Management</p>
        </div>
        <div class="col-4 text-end">
            <div class="badge bg-primary bg-opacity-10 text-primary p-2 px-3 rounded-pill border border-primary border-opacity-25">
                <i class="bi bi-calendar3 me-2"></i>@DateTime.Now.ToString("MMMM dd, yyyy")
            </div>
        </div>
    </div>
</div>

<!-- ========================================== -->
<!-- PRODUCTION WORKER DASHBOARD                -->
<!-- ========================================== -->
<AuthorizeView Roles="ProductionWorker" Context="workerContext">
    <div class="row g-4 mb-5">
        <!-- Tasks KPI -->
        <div class="col-md-4">
            <div class="dash-kpi dash-kpi-purple">
                <div class="dash-kpi-icon">
                    <i class="bi bi-list-stars"></i>
                </div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@workerPendingTasks</div>
                    <div class="dash-kpi-label">Active Tasks</div>
                </div>
            </div>
        </div>
        <!-- Completed KPI -->
        <div class="col-md-4">
            <div class="dash-kpi dash-kpi-green">
                <div class="dash-kpi-icon">
                    <i class="bi bi-patch-check"></i>
                </div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@workerCompletedToday</div>
                    <div class="dash-kpi-label">Finished Today</div>
                </div>
            </div>
        </div>
        <!-- Climate KPI -->
        <div class="col-md-4">
            <div class="dash-kpi @(isSafe ? "dash-kpi-cyan" : "dash-kpi-amber")">
                <div class="dash-kpi-icon">
                    <i class="bi bi-thermometer-half"></i>
                </div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@(currentTemp == "--" || currentTemp == "N/A" ? "--" : currentTemp + "°C")</div>
                    <div class="dash-kpi-label">Workshop: @(isSafe ? "Optimal" : "Check ESD")</div>
                </div>
                @if (!isSafe && currentTemp != "N/A" && currentTemp != "--")
                {
                    <div class="position-absolute top-0 end-0 m-2">
                        <span class="badge bg-danger p-1 rounded-circle"><i class="bi bi-exclamation-triangle"></i></span>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-kanban me-2 text-primary"></i>My Assigned Work Orders</h5>
                        <a href="tasks/assigned" class="btn btn-sm btn-outline-primary">View Full List</a>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (workerOrders.Any())
                    {
                         <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead style="background: #f8f9fa;">
                                    <tr>
                                        <th class="ps-4 py-3">Reference</th>
                                        <th class="py-3">Task Details</th>
                                        <th class="py-3">Status</th>
                                        <th class="py-3 text-end pe-4">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in workerOrders)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-600">#@order.OrderID</td>
                                            <td>
                                                <div class="fw-500">@order.OrderDescription</div>
                                                <div class="text-muted small">Target Qty: @order.BatchQuantity</div>
                                            </td>
                                            <td>
                                                <span class="badge rounded-pill @GetStatusClass(order.Status)">@order.Status</span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <a href="tasks/assigned" class="btn btn-sm btn-light border">
                                                    Open <i class="bi bi-arrow-right ms-1"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="bg-light rounded-circle d-inline-flex p-3 mb-3">
                                <i class="bi bi-check-all text-success fs-3"></i>
                            </div>
                            <h6 class="fw-bold">All caught up!</h6>
                            <p class="text-muted small mb-0">No active production tasks assigned to you right now.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</AuthorizeView>

<!-- ========================================== -->
<!-- PRODUCTION MANAGER DASHBOARD               -->
<!-- ========================================== -->
<AuthorizeView Roles="ProductionManager" Context="managerContext">
    <div class="row g-4 mb-5">
        <div class="col-md-6 col-lg-3">
            <div class="dash-kpi dash-kpi-purple">
                <div class="dash-kpi-icon"><i class="bi bi-kanban-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@managerActivePlans</div>
                    <div class="dash-kpi-label">Active Operations</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
             <div class="dash-kpi dash-kpi-red">
                <div class="dash-kpi-icon"><i class="bi bi-lightning-charge-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@managerBottlenecks</div>
                    <div class="dash-kpi-label">Bottlenecks</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="dash-kpi @(lowStockCount > 0 ? "dash-kpi-amber" : "dash-kpi-green")">
                <div class="dash-kpi-icon"><i class="bi bi-box-seam-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@lowStockCount</div>
                    <div class="dash-kpi-label">Low Stock Alerts</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="dash-kpi dash-kpi-blue">
                <div class="dash-kpi-icon"><i class="bi bi-wallet2"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">&#8369;@todayCost.ToString("N0")</div>
                    <div class="dash-kpi-label">Costs Recorded</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100 overflow-hidden">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold text-dark"><i class="bi bi-speedometer2 me-2 text-primary"></i>Live Production Status</h6>
                </div>
                <div class="card-body p-0">
                     @if (managerRecentOrders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4">ID</th>
                                        <th>Description</th>
                                        <th>Progress</th>
                                        <th>Assignee</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in managerRecentOrders)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-600">#@order.OrderID</td>
                                            <td>@order.OrderDescription</td>
                                            <td><span class="badge rounded-pill @GetStatusClass(order.Status)">@order.Status</span></td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px; font-size: 0.75rem;">
                                                        @(order.User?.UserName?.Substring(0, 1).ToUpper() ?? "U")
                                                    </div>
                                                    <span class="small">@(order.User?.UserName ?? "Unassigned")</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                         <div class="text-center py-5 text-muted">No recent activity detected.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
             <div class="card border-0 shadow-sm h-100 glass-card">
                <div class="card-header bg-transparent py-3 border-0">
                    <h6 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-exclamation-octagon-fill text-danger me-2"></i>Critical Inventory
                    </h6>
                </div>
                <div class="card-body">
                    @if (lowStockComponents.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var component in lowStockComponents)
                            {
                                <div class="p-3 bg-white rounded-3 border-start border-danger border-4 shadow-sm activity-item">
                                    <div class="activity-content">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="fw-bold text-dark">@component.ComponentName</span>
                                            <span class="badge bg-danger">@component.CurrentStock</span>
                                        </div>
                                        <div class="text-muted small">Minimum Required: @component.MinStockLevel</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="p-3 bg-success bg-opacity-10 rounded-circle d-inline-flex mb-3 text-success">
                                <i class="bi bi-shield-check fs-2"></i>
                            </div>
                            <h6 class="fw-bold text-success">Stock Healthy</h6>
                            <p class="text-muted small mb-0">All key components are sufficiently stocked.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</AuthorizeView>

<!-- ========================================== -->
<!-- ADMINISTRATOR DASHBOARD                    -->
<!-- ========================================== -->
<AuthorizeView Roles="Administrator" Context="adminContext">
     <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="dash-kpi dash-kpi-purple">
                <div class="dash-kpi-icon"><i class="bi bi-people-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@adminTotalUsers</div>
                    <div class="dash-kpi-label">Active Personnel</div>
                </div>
            </div>
        </div>
         <div class="col-md-4">
            <div class="dash-kpi dash-kpi-amber">
                <div class="dash-kpi-icon"><i class="bi bi-person-x-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@adminArchivedUsers</div>
                    <div class="dash-kpi-label">Deactivated Accounts</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dash-kpi dash-kpi-blue">
                <div class="dash-kpi-icon"><i class="bi bi-shield-lock-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@adminRecentLogsCount</div>
                    <div class="dash-kpi-label">Recent Audits (24h)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
         <div class="col-12">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>System Security & Audit Log</h6>
                </div>
                <div class="card-body p-0">
                     @if (adminRecentLogs.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4">Personnel</th>
                                        <th>Security Event</th>
                                        <th>Details</th>
                                        <th class="pe-4 text-end">Occurrence</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in adminRecentLogs)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="tb-dropdown-avatar me-2" style="width: 28px; height: 28px; font-size: 0.8rem;">
                                                        @(log.User?.UserName?.Substring(0,1).ToUpper() ?? "?")
                                                    </div>
                                                    <span class="fw-500">@(log.User?.UserName ?? "System")</span>
                                                </div>
                                            </td>
                                            <td><span class="badge rounded-pill bg-secondary bg-opacity-10 text-dark border">@log.ActionType</span></td>
                                            <td class="small">@log.Details</td>
                                            <td class="pe-4 text-end text-muted small">@log.Timestamp.ToString("g")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">No recent security events logged.</div>
                    }
                </div>
            </div>
         </div>
    </div>
</AuthorizeView>


<!-- ========================================== -->
<!-- SUPERADMIN DASHBOARD                       -->
<!-- ========================================== -->
<AuthorizeView Roles="Superadmin" Context="superContext">
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="dash-kpi dash-kpi-green shadow-sm border-0 glass-card">
                <div class="dash-kpi-icon"><i class="bi bi-cpu-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value text-success">ONLINE</div>
                    <div class="dash-kpi-label">Core Engine Status</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="dash-kpi dash-kpi-purple shadow-sm border-0 glass-card">
                <div class="dash-kpi-icon"><i class="bi bi-hdd-network-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@superConfiguredFacilityCount/@superFacilityCount</div>
                    <div class="dash-kpi-label">Node Connectivity</div>
                </div>
            </div>
        </div>
         <div class="col-md-6 col-lg-4">
            <div class="dash-kpi dash-kpi-blue shadow-sm border-0 glass-card">
                <div class="dash-kpi-icon"><i class="bi bi-grid-3x3-gap-fill"></i></div>
                <div class="dash-kpi-body">
                    <div class="dash-kpi-value">@superFacilityCount</div>
                    <div class="dash-kpi-label">Active Facilities</div>
                </div>
            </div>
        </div>
    </div>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    [Inject] private production_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    // Facility access
    private int? userFacilityId;
    private bool userIsSuperAdmin;

    // Worker Stats
    private int workerPendingTasks = 0;
    private int workerCompletedToday = 0;
    private List<WorkOrder> workerOrders = new();
    private string currentTemp = "--";
    private bool isSafe = true;

    private string GetEnvIconStyle()
    {
        if (currentTemp == "--" || currentTemp == "N/A") return "background-color: #696969; color: white;";
        
        if (decimal.TryParse(currentTemp, out decimal temp))
        {
            if (temp > 40) return "background-color: #D10000; color: white;";
            if (temp > 35) return "background-color: #EA580C; color: white;";
            if (temp < 10) return "background-color: #0062FF; color: white;";
        }
        
        return isSafe ? "background-color: #059669; color: white;" : "background-color: #EA580C; color: white;";
    }

    // Manager Stats
    private int managerActivePlans = 0;
    private int managerBottlenecks = 0;
    private int lowStockCount = 0;
    private decimal todayCost = 0;
    private List<WorkOrder> managerRecentOrders = new();
    private List<ComponentStockInfo> lowStockComponents = new();

    // Admin Stats
    private int adminTotalUsers = 0;
    private int adminArchivedUsers = 0;
    private int adminRecentLogsCount = 0;
    private List<ActivityLog> adminRecentLogs = new();

    // Superadmin Stats
    private int superFacilityCount = 0;
    private int superConfiguredFacilityCount = 0;

    private class ComponentStockInfo
    {
        public string ComponentName { get; set; } = "";
        public int MinStockLevel { get; set; }
        public int CurrentStock { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        
        if (!user.Identity?.IsAuthenticated ?? true) return;

        userIsSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();

        if (user.IsInRole("ProductionWorker"))
        {
            await LoadWorkerData(user);
        }
        else if (user.IsInRole("ProductionManager"))
        {
            await LoadManagerData();
        }
        else if (user.IsInRole("Administrator"))
        {
            await LoadAdminData();
        }
        else if (user.IsInRole("Superadmin"))
        {
            await LoadSuperAdminData();
        }
    }

    private async Task LoadWorkerData(ClaimsPrincipal user)
    {
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId == null) return;

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        workerPendingTasks = await context.WorkOrders
            .CountAsync(o => o.UserID == userId && (o.Status == "Pending" || o.Status == "In Progress"));
            
        var todayStart = DateTime.Today;
        var todayEnd = todayStart.AddDays(1);
        workerCompletedToday = await context.WorkOrders
            .CountAsync(o => o.UserID == userId && o.Status == "Completed" && o.EndTime != null && o.EndTime >= todayStart && o.EndTime < todayEnd);

        workerOrders = await context.WorkOrders
            .Where(o => o.UserID == userId && (o.Status == "Pending" || o.Status == "In Progress"))
            .OrderBy(o => o.OrderID)
            .Take(5)
            .ToListAsync();

        var facility = userFacilityId.HasValue ? await context.Facilities.FindAsync(userFacilityId.Value) : null;
        
        // Fetch Weather
        try 
        {
             string apiKey = facility?.APIKeyOpenWeather ?? "";
             string location = facility?.Location ?? "";
             var weather = await WeatherService.GetCurrentWeatherAsync(location, apiKey);
             if (weather != null)
             {
                 currentTemp = weather.Temperature.ToString("F1");
                 isSafe = weather.Humidity >= 40 && weather.Humidity <= 60;
             }
             else
             {
                 currentTemp = "N/A";
                 isSafe = false;
             }
        }
        catch
        {
            currentTemp = "N/A";
            isSafe = false;
        }
    }

    private async Task LoadManagerData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var planQuery = context.ProductionPlans.Where(p => p.Status == "Active").AsQueryable();
        if (userFacilityId.HasValue)
            planQuery = planQuery.Where(p => p.FacilityID == userFacilityId.Value);
        managerActivePlans = await planQuery.CountAsync();

        var bottleneckQuery = context.WorkOrders.Where(w => w.Status == "Pending" || w.Status == "Quality Check").AsQueryable();
        if (userFacilityId.HasValue)
            bottleneckQuery = bottleneckQuery.Where(w => w.FacilityID == userFacilityId.Value);
        managerBottlenecks = await bottleneckQuery.CountAsync();

        var todayStart = DateTime.Today;
        var todayEnd = todayStart.AddDays(1);
        var costQuery = context.Costs.Where(c => c.RecordedDate >= todayStart && c.RecordedDate < todayEnd).AsQueryable();
        if (userFacilityId.HasValue)
            costQuery = costQuery.Where(c => c.FacilityID == userFacilityId.Value);
        var costNullable = await costQuery.SumAsync(c => (decimal?)c.Amount);
        todayCost = costNullable ?? 0m;

        var orderQuery = context.WorkOrders.Include(w => w.User).OrderByDescending(w => w.OrderID).AsQueryable();
        if (userFacilityId.HasValue)
            orderQuery = orderQuery.Where(w => w.FacilityID == userFacilityId.Value);
        managerRecentOrders = await orderQuery.Take(5).ToListAsync();

        await CheckLowStock(context);
    }

    private async Task CheckLowStock(ApplicationDbContext context)
    {
        var componentQuery = context.Components.Where(c => !c.IsArchived && c.MinStockLevel > 0).AsQueryable();
        if (userFacilityId.HasValue)
            componentQuery = componentQuery.Where(c => c.FacilityID == userFacilityId.Value);
        var components = await componentQuery.ToListAsync();
            
        var txnQuery = context.InventoryTransactions.AsQueryable();
        if (userFacilityId.HasValue)
            txnQuery = txnQuery.Where(t => t.FacilityID == userFacilityId.Value);
        var allTransactions = await txnQuery.ToListAsync();
        
        lowStockComponents.Clear();

        foreach (var comp in components)
        {
            var compTransactions = allTransactions.Where(t => t.ComponentID == comp.ComponentID).ToList();
            
            var inbound = compTransactions.Where(t => t.TransactionType == "Inbound").Sum(t => t.Quantity);
            var outbound = compTransactions.Where(t => t.TransactionType == "Outbound").Sum(t => t.Quantity);
            var adjustments = compTransactions.Where(t => t.TransactionType == "Adjustment").Sum(t => t.Quantity);
            
            var currentStock = (inbound + adjustments) - outbound;

            if (currentStock < comp.MinStockLevel)
            {
                lowStockComponents.Add(new ComponentStockInfo
                {
                    ComponentName = comp.ComponentName,
                    MinStockLevel = comp.MinStockLevel,
                    CurrentStock = currentStock
                });
            }
        }
        lowStockCount = lowStockComponents.Count;
    }

    private async Task LoadAdminData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        if (userFacilityId.HasValue)
        {
            adminTotalUsers = await context.Users.CountAsync(u => u.FacilityID == userFacilityId.Value);
            adminArchivedUsers = await context.Users.CountAsync(u => u.FacilityID == userFacilityId.Value && u.IsArchived);
        }
        else
        {
            adminTotalUsers = await context.Users.CountAsync();
            adminArchivedUsers = await context.Users.CountAsync(u => u.IsArchived);
        }
         
        var yesterday = DateTime.Now.AddHours(-24);
        var logQuery = context.ActivityLogs.Where(l => l.Timestamp >= yesterday).AsQueryable();
        if (userFacilityId.HasValue)
            logQuery = logQuery.Where(l => l.FacilityID == userFacilityId.Value);
        adminRecentLogsCount = await logQuery.CountAsync();
         
        var logsDetailQuery = context.ActivityLogs.Include(l => l.User).OrderByDescending(l => l.Timestamp).AsQueryable();
        if (userFacilityId.HasValue)
            logsDetailQuery = logsDetailQuery.Where(l => l.FacilityID == userFacilityId.Value);
        adminRecentLogs = await logsDetailQuery.Take(10).ToListAsync();
    }

    private async Task LoadSuperAdminData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        superFacilityCount = await context.Facilities.CountAsync();
        superConfiguredFacilityCount = await context.Facilities.CountAsync(f => !string.IsNullOrEmpty(f.APIKeyOpenWeather) && !string.IsNullOrEmpty(f.APIKeyExchangeRate));
    }

    private string GetStatusClass(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "In Progress" => "bg-primary",
        "Completed" => "bg-success",
        "Quality Check" => "bg-warning text-dark",
        _ => "bg-light text-dark"
    };
}

