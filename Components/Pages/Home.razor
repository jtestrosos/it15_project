@page "/"
@using production_system.Data
@using production_system.Models
@using production_system.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@attribute [Authorize]
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IWeatherService WeatherService

<PageTitle>NodeSync | Dashboard</PageTitle>

<div class="page-header mb-4">
    <h1>Dashboard</h1>
    <p class="mb-0 opacity-75">Welcome to the NodeSync Production System!</p>
</div>

<!-- ========================================== -->
<!-- PRODUCTION WORKER DASHBOARD                -->
<!-- ========================================== -->
<AuthorizeView Roles="ProductionWorker" Context="workerContext">
    <div class="row g-4 mb-4">
        <!-- Pending Tasks -->
        <div class="col-md-4">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3" style="background-color: #FF964F; color: white;">
                        <i class="bi bi-list-task"></i>
                    </div>
                    <div>
                        <div class="widget-value">@workerPendingTasks</div>
                        <div class="widget-label">My Pending Tasks</div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Performance -->
        <div class="col-md-4">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3" style="background-color: #56AE57; color: white;">
                        <i class="bi bi-check2-circle"></i>
                    </div>
                    <div>
                        <div class="widget-value">@workerCompletedToday</div>
                        <div class="widget-label">Completed Today</div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Environment (Using placeholder data if service fails/unconfigured) -->
        <div class="col-md-4">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3" style="@GetEnvIconStyle()">
                        <i class="bi bi-thermometer-half"></i>
                    </div>
                    <div>
                        <div class="widget-value">@(currentTemp == "--" || currentTemp == "N/A" ? currentTemp : currentTemp + " °C")</div>
                        <div class="widget-label">ESD Safety: @(isSafe ? "Safe" : "Risk")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">My Work Orders</h5>
                </div>
                <div class="card-body">
                    @if (workerOrders.Any())
                    {
                         <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Order ID</th>
                                        <th>Description</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in workerOrders)
                                    {
                                        <tr>
                                            <td>@order.OrderID</td>
                                            <td>@order.OrderDescription</td>
                                            <td><span class="badge @GetStatusClass(order.Status)">@order.Status</span></td>
                                            <td>
                                                <a href="tasks/assigned" class="btn btn-sm btn-primary">View</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">No pending work assigned to you.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</AuthorizeView>

<!-- ========================================== -->
<!-- PRODUCTION MANAGER DASHBOARD               -->
<!-- ========================================== -->
<AuthorizeView Roles="ProductionManager" Context="managerContext">
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3" style="background-color: #8F00FF; color: white;">
                        <i class="bi bi-clipboard-data"></i>
                    </div>
                    <div>
                        <div class="widget-value">@managerActivePlans</div>
                        <div class="widget-label">Active Plans</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
             <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3 bg-danger text-white">
                         <i class="bi bi-exclamation-triangle"></i>
                    </div>
                    <div>
                        <div class="widget-value">@managerBottlenecks</div>
                        <div class="widget-label">Bottlenecks</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3 @(lowStockCount > 0 ? "bg-warning text-dark" : "bg-success text-white")">
                         <i class="bi bi-box-seam"></i>
                    </div>
                    <div>
                        <div class="widget-value">@lowStockCount</div>
                        <div class="widget-label">Low Stock Items</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-3">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3 bg-success text-white">
                         <i class="bi bi-currency-dollar"></i>
                    </div>
                    <div>
                        <div class="widget-value">?@todayCost.ToString("N0")</div>
                        <div class="widget-label">Costs Today</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0">Production Overview</h5>
                </div>
                <div class="card-body">
                    <h5>Recent Orders</h5>
                     @if (managerRecentOrders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Description</th>
                                        <th>Status</th>
                                        <th>User</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in managerRecentOrders)
                                    {
                                        <tr>
                                            <td>@order.OrderID</td>
                                            <td>@order.OrderDescription</td>
                                            <td><span class="badge @GetStatusClass(order.Status)">@order.Status</span></td>
                                            <td>@order.User?.UserName</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                         <p class="text-muted text-center py-2">No recent production activity.</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
             <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 pb-0">
                    <h6 class="mb-0 fw-bold text-dark text-uppercase tracking-wide">
                        <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Low Stock Alerts
                    </h6>
                </div>
                <div class="card-body">
                    @if (lowStockComponents.Any())
                    {
                        <div class="d-flex flex-column gap-3 mt-2">
                            @foreach (var component in lowStockComponents)
                            {
                                <div class="p-3 bg-light rounded-3 border-start border-danger border-4 shadow-sm">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <h6 class="mb-0 fw-bold text-dark">@component.ComponentName</h6>
                                        <span class="badge bg-danger">@component.CurrentStock Left</span>
                                    </div>
                                    <small class="text-muted"><i class="bi bi-box-seam me-1"></i>Min Required: @component.MinStockLevel</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 d-flex flex-column align-items-center justify-content-center h-100">
                            <div class="p-3 bg-success bg-opacity-10 rounded-circle d-inline-flex mb-3 text-success">
                                <i class="bi bi-check-circle-fill fs-2"></i>
                            </div>
                            <h6 class="fw-bold mb-1 text-success">Inventory Healthy</h6>
                            <p class="text-muted small mb-0">No components are running dangerously low.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</AuthorizeView>

<!-- ========================================== -->
<!-- ADMINISTRATOR DASHBOARD                    -->
<!-- ========================================== -->
<AuthorizeView Roles="Administrator" Context="adminContext">
     <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3 bg-primary text-white">
                        <i class="bi bi-people"></i>
                    </div>
                    <div>
                        <div class="widget-value">@adminTotalUsers</div>
                        <div class="widget-label">Total Users</div>
                    </div>
                </div>
            </div>
        </div>
         <div class="col-md-4">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3 bg-warning text-dark">
                        <i class="bi bi-person-exclamation"></i>
                    </div>
                    <div>
                        <div class="widget-value">@adminArchivedUsers</div>
                        <div class="widget-label">Archived Users</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="dashboard-widget">
                <div class="d-flex align-items-center mb-3">
                    <div class="widget-icon me-3 bg-info text-white">
                        <i class="bi bi-activity"></i>
                    </div>
                    <div>
                        <div class="widget-value">@adminRecentLogsCount</div>
                        <div class="widget-label">Activities (24h)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
         <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Recent System Activity</h5>
                </div>
                <div class="card-body">
                     @if (adminRecentLogs.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Action</th>
                                        <th>Details</th>
                                        <th>Time</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in adminRecentLogs)
                                    {
                                        <tr>
                                            <td>@log.User?.UserName</td>
                                            <td><span class="badge bg-secondary">@log.ActionType</span></td>
                                            <td>@log.Details</td>
                                            <td class="text-muted small">@log.Timestamp.ToString("g")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center py-4">No recent audit logs found.</p>
                    }
                </div>
            </div>
         </div>
    </div>
</AuthorizeView>


<!-- ========================================== -->
<!-- SUPERADMIN DASHBOARD                       -->
<!-- ========================================== -->
<AuthorizeView Roles="Superadmin" Context="superContext">
    <style>
        .super-card {
            border-top: 4px solid #fff !important;
            transition: all 0.2s ease-in-out;
            cursor: default;
        }
        .super-card:hover {
            border-top: 4px solid #8F00FF !important;
        }
        .super-card .card-icon-accent {
            color: #000 !important;
            transition: color 0.2s ease-in-out;
        }
        .super-card:hover .card-icon-accent {
            color: #8F00FF !important;
        }
    </style>
    <div class="row g-4 mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="card bg-white h-100 border-0 shadow-sm super-card">
                <div class="card-body text-center">
                    <i class="bi bi-server fs-1 mb-3 card-icon-accent"></i>
                    <h3 class="text-dark fw-bold">System Status</h3>
                    <p class="mb-0 fw-bold fs-5" style="color: #56AE57;">ONLINE</p>
                    <small class="text-secondary fw-semibold">Database Connected</small>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-lg-4">
            <div class="card bg-white h-100 border-0 shadow-sm super-card">
                <div class="card-body text-center">
                    <i class="bi bi-cloud-arrow-up fs-1 mb-3 card-icon-accent"></i>
                    <h3 class="text-dark fw-bold">API Configuration</h3>
                    @{
                        bool isComplete = superFacilityCount > 0 && superConfiguredFacilityCount == superFacilityCount;
                        string configColor = isComplete ? "#56AE57" : "#FF964F";
                    }
                    <p class="mb-0 fw-bold fs-5" style="color: @configColor;">@superConfiguredFacilityCount / @superFacilityCount Configured</p>
                    <small class="text-secondary fw-semibold">OpenWeather & ExchangeRate</small>
                </div>
            </div>
        </div>
         <div class="col-md-6 col-lg-4">
            <div class="card bg-white h-100 border-0 shadow-sm super-card">
                <div class="card-body text-center">
                    <i class="bi bi-building fs-1 mb-3 card-icon-accent"></i>
                    <h3 class="text-dark fw-bold">Facilities</h3>
                    <p class="mb-0 fs-4 text-dark fw-bold">@superFacilityCount</p>
                    <small class="text-secondary fw-semibold">Registered Facilities</small>
                </div>
            </div>
        </div>
    </div>
</AuthorizeView>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthStateTask { get; set; } = default!;

    [Inject] private production_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    // Facility access
    private int? userFacilityId;
    private bool userIsSuperAdmin;

    // Worker Stats
    private int workerPendingTasks = 0;
    private int workerCompletedToday = 0;
    private List<WorkOrder> workerOrders = new();
    private string currentTemp = "--";
    private bool isSafe = true;

    private string GetEnvIconStyle()
    {
        if (currentTemp == "--" || currentTemp == "N/A") return "background-color: #696969; color: white;";
        
        if (decimal.TryParse(currentTemp, out decimal temp))
        {
            if (temp > 40) return "background-color: #D10000; color: white;";
            if (temp > 35) return "background-color: #FF964F; color: white;";
            if (temp < 10) return "background-color: #5C5CFF; color: white;";
        }
        
        return isSafe ? "background-color: #56AE57; color: white;" : "background-color: #FF964F; color: white;";
    }

    // Manager Stats
    private int managerActivePlans = 0;
    private int managerBottlenecks = 0;
    private int lowStockCount = 0;
    private decimal todayCost = 0;
    private List<WorkOrder> managerRecentOrders = new();
    private List<ComponentStockInfo> lowStockComponents = new();

    // Admin Stats
    private int adminTotalUsers = 0;
    private int adminArchivedUsers = 0;
    private int adminRecentLogsCount = 0;
    private List<ActivityLog> adminRecentLogs = new();

    // Superadmin Stats
    private int superFacilityCount = 0;
    private int superConfiguredFacilityCount = 0;

    private class ComponentStockInfo
    {
        public string ComponentName { get; set; } = "";
        public int MinStockLevel { get; set; }
        public int CurrentStock { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateTask;
        var user = authState.User;
        
        if (!user.Identity?.IsAuthenticated ?? true) return;

        userIsSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();

        if (user.IsInRole("ProductionWorker"))
        {
            await LoadWorkerData(user);
        }
        else if (user.IsInRole("ProductionManager"))
        {
            await LoadManagerData();
        }
        else if (user.IsInRole("Administrator"))
        {
            await LoadAdminData();
        }
        else if (user.IsInRole("Superadmin"))
        {
            await LoadSuperAdminData();
        }
    }

    private async Task LoadWorkerData(ClaimsPrincipal user)
    {
        var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId == null) return;

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        workerPendingTasks = await context.WorkOrders
            .CountAsync(o => o.UserID == userId && (o.Status == "Pending" || o.Status == "In Progress"));
            
        var todayStart = DateTime.Today;
        var todayEnd = todayStart.AddDays(1);
        workerCompletedToday = await context.WorkOrders
            .CountAsync(o => o.UserID == userId && o.Status == "Completed" && o.EndTime != null && o.EndTime >= todayStart && o.EndTime < todayEnd);

        workerOrders = await context.WorkOrders
            .Where(o => o.UserID == userId && (o.Status == "Pending" || o.Status == "In Progress"))
            .OrderBy(o => o.OrderID)
            .Take(5)
            .ToListAsync();

        var facility = userFacilityId.HasValue ? await context.Facilities.FindAsync(userFacilityId.Value) : null;
        
        // Fetch Weather
        try 
        {
             string apiKey = facility?.APIKeyOpenWeather ?? "";
             string location = facility?.Location ?? "";
             var weather = await WeatherService.GetCurrentWeatherAsync(location, apiKey);
             if (weather != null)
             {
                 currentTemp = weather.Temperature.ToString("F1");
                 isSafe = weather.Humidity >= 40 && weather.Humidity <= 60;
             }
             else
             {
                 currentTemp = "N/A";
                 isSafe = false;
             }
        }
        catch
        {
            currentTemp = "N/A";
            isSafe = false;
        }
    }

    private async Task LoadManagerData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var planQuery = context.ProductionPlans.Where(p => p.Status == "Active").AsQueryable();
        if (userFacilityId.HasValue)
            planQuery = planQuery.Where(p => p.FacilityID == userFacilityId.Value);
        managerActivePlans = await planQuery.CountAsync();

        var bottleneckQuery = context.WorkOrders.Where(w => w.Status == "Pending" || w.Status == "Quality Check").AsQueryable();
        if (userFacilityId.HasValue)
            bottleneckQuery = bottleneckQuery.Where(w => w.FacilityID == userFacilityId.Value);
        managerBottlenecks = await bottleneckQuery.CountAsync();

        var todayStart = DateTime.Today;
        var todayEnd = todayStart.AddDays(1);
        var costQuery = context.Costs.Where(c => c.RecordedDate >= todayStart && c.RecordedDate < todayEnd).AsQueryable();
        if (userFacilityId.HasValue)
            costQuery = costQuery.Where(c => c.FacilityID == userFacilityId.Value);
        var costNullable = await costQuery.SumAsync(c => (decimal?)c.Amount);
        todayCost = costNullable ?? 0m;

        var orderQuery = context.WorkOrders.Include(w => w.User).OrderByDescending(w => w.OrderID).AsQueryable();
        if (userFacilityId.HasValue)
            orderQuery = orderQuery.Where(w => w.FacilityID == userFacilityId.Value);
        managerRecentOrders = await orderQuery.Take(5).ToListAsync();

        await CheckLowStock(context);
    }

    private async Task CheckLowStock(ApplicationDbContext context)
    {
        var componentQuery = context.Components.Where(c => !c.IsArchived && c.MinStockLevel > 0).AsQueryable();
        if (userFacilityId.HasValue)
            componentQuery = componentQuery.Where(c => c.FacilityID == userFacilityId.Value);
        var components = await componentQuery.ToListAsync();
            
        var txnQuery = context.InventoryTransactions.AsQueryable();
        if (userFacilityId.HasValue)
            txnQuery = txnQuery.Where(t => t.FacilityID == userFacilityId.Value);
        var allTransactions = await txnQuery.ToListAsync();
        
        lowStockComponents.Clear();

        foreach (var comp in components)
        {
            var compTransactions = allTransactions.Where(t => t.ComponentID == comp.ComponentID).ToList();
            
            var inbound = compTransactions.Where(t => t.TransactionType == "Inbound").Sum(t => t.Quantity);
            var outbound = compTransactions.Where(t => t.TransactionType == "Outbound").Sum(t => t.Quantity);
            var adjustments = compTransactions.Where(t => t.TransactionType == "Adjustment").Sum(t => t.Quantity);
            
            var currentStock = (inbound + adjustments) - outbound;

            if (currentStock < comp.MinStockLevel)
            {
                lowStockComponents.Add(new ComponentStockInfo
                {
                    ComponentName = comp.ComponentName,
                    MinStockLevel = comp.MinStockLevel,
                    CurrentStock = currentStock
                });
            }
        }
        lowStockCount = lowStockComponents.Count;
    }

    private async Task LoadAdminData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        if (userFacilityId.HasValue)
        {
            adminTotalUsers = await context.Users.CountAsync(u => u.FacilityID == userFacilityId.Value);
            adminArchivedUsers = await context.Users.CountAsync(u => u.FacilityID == userFacilityId.Value && u.IsArchived);
        }
        else
        {
            adminTotalUsers = await context.Users.CountAsync();
            adminArchivedUsers = await context.Users.CountAsync(u => u.IsArchived);
        }
         
        var yesterday = DateTime.Now.AddHours(-24);
        var logQuery = context.ActivityLogs.Where(l => l.Timestamp >= yesterday).AsQueryable();
        if (userFacilityId.HasValue)
            logQuery = logQuery.Where(l => l.FacilityID == userFacilityId.Value);
        adminRecentLogsCount = await logQuery.CountAsync();
         
        var logsDetailQuery = context.ActivityLogs.Include(l => l.User).OrderByDescending(l => l.Timestamp).AsQueryable();
        if (userFacilityId.HasValue)
            logsDetailQuery = logsDetailQuery.Where(l => l.FacilityID == userFacilityId.Value);
        adminRecentLogs = await logsDetailQuery.Take(10).ToListAsync();
    }

    private async Task LoadSuperAdminData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        superFacilityCount = await context.Facilities.CountAsync();
        superConfiguredFacilityCount = await context.Facilities.CountAsync(f => !string.IsNullOrEmpty(f.APIKeyOpenWeather) && !string.IsNullOrEmpty(f.APIKeyExchangeRate));
    }

    private string GetStatusClass(string status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "In Progress" => "bg-primary",
        "Completed" => "bg-success",
        "Quality Check" => "bg-warning text-dark",
        _ => "bg-light text-dark"
    };
}

