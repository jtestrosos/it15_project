@page "/inventory/bom"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using manufacturing_system.Data
@using manufacturing_system.Models

@attribute [Authorize(Roles = "ProductionManager,Superadmin")]
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager NavigationManager

<PageTitle>NodeSync | Bill of Materials</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Bill of Materials</h1>
        <p class="text-muted mb-0">Define component structures for products.</p>
    </div>
    <div class="d-flex flex-column gap-2 align-items-end">
        <button class="btn btn-outline-secondary" @onclick="ToggleArchivedView">
            <i class="bi @(ShowArchived ? "bi-eye-slash" : "bi-archive") me-1"></i> 
            @(ShowArchived ? "Show Active" : "Show Archived")
        </button>
        <button class="btn btn-primary" @onclick="OpenCreateModal" disabled="@ShowArchived">
            <i class="bi bi-plus-lg me-1"></i> Add BOM Item
        </button>
    </div>
</div>

@if (ShowCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New BOM Item</h5>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="NewBOM" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Product</label>
                            <InputSelect class="form-select" @bind-Value="NewBOM.ProductID">
                                <option value="0">Select Product</option>
                                @foreach (var p in products)
                                {
                                    <option value="@p.ProductID">@p.ProductName</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Component</label>
                            <InputSelect class="form-select" @bind-Value="NewBOM.ComponentID">
                                <option value="0">Select Component</option>
                                @foreach (var c in components)
                                {
                                    <option value="@c.ComponentID">@c.ComponentName</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Quantity Required</label>
                                <InputNumber class="form-control" @bind-Value="NewBOM.QuantityRequired" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Unit of Measure</label>
                                <InputText class="form-control" @bind-Value="NewBOM.UnitOfMeasure" />
                            </div>
                        </div>
                        
                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseCreateModal">Cancel</button>
                             <button type="submit" class="btn btn-primary">Save BOM Item</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (boms == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading BOM data...</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-diagram-3 me-1"></i>
                @(ShowArchived ? "Archived Items" : "Active Items")
            </span>
            <span class="badge bg-light text-dark border">@boms.Count item(s)</span>
        </div>
        <div class="card-body p-0">
            @if (!boms.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2" style="opacity: 0.3;"></i>
                    @if (ShowArchived)
                    {
                        <p>No archived BOM items.</p>
                    }
                    else
                    {
                        <p>No BOM items yet. Click <strong>Add BOM Item</strong> to create one.</p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Product</th>
                                <th>Component</th>
                                <th>Qty Required</th>
                                <th>UoM</th>
                                <th class="text-center" style="width: 140px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bom in boms)
                            {
                                <tr class="@(bom.IsArchived ? "table-light text-muted" : "")">
                                    <td class="ps-4 fw-bold">@bom.Product?.ProductName</td>
                                    <td>@bom.Component?.ComponentName</td>
                                    <td>@bom.QuantityRequired</td>
                                    <td><span class="badge bg-light text-dark border">@bom.UnitOfMeasure</span></td>
                                    <td class="text-center">
                                        @if (!bom.IsArchived)
                                        {
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => ArchiveBOM(bom)" title="Archive">
                                                <i class="bi bi-archive"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => RestoreBOM(bom)" title="Restore">
                                                <i class="bi bi-arrow-counterclockwise"></i> Restore
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<BillOfMaterial>? boms;
    private List<Product> products = new();
    private List<Component> components = new();
    private bool ShowCreateModal = false;
    private bool ShowArchived = false;
    private BillOfMaterial NewBOM = new();
    private int? userFacilityId;
    private bool isSuperAdmin;

    [Inject] private manufacturing_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var productQuery = context.Products.AsQueryable();
        var componentQuery = context.Components.AsQueryable();
        
        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            productQuery = productQuery.Where(p => p.FacilityID == userFacilityId.Value);
            componentQuery = componentQuery.Where(c => c.FacilityID == userFacilityId.Value);
        }

        products = await productQuery.ToListAsync();
        components = await componentQuery.ToListAsync();
        
        var query = context.BillOfMaterials
            .Include(b => b.Product)
            .Include(b => b.Component)
            .AsQueryable();

        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            query = query.Where(b => b.FacilityID == userFacilityId.Value);
        }

        if (ShowArchived)
        {
            query = query.Where(b => b.IsArchived);
        }
        else
        {
            query = query.Where(b => !b.IsArchived);
        }

        boms = await query.ToListAsync();
    }

    private void OpenCreateModal()
    {
        NewBOM = new BillOfMaterial();
        ShowCreateModal = true;
    }

    private void CloseCreateModal()
    {
        ShowCreateModal = false;
    }

    private async Task HandleValidSubmit()
    {
        if (NewBOM.ProductID == 0 || NewBOM.ComponentID == 0) return;

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        NewBOM.IsArchived = false;
        NewBOM.FacilityID = userFacilityId;
        context.BillOfMaterials.Add(NewBOM);
        await context.SaveChangesAsync();
        await LoadData();
        CloseCreateModal();
    }

    private async Task ArchiveBOM(BillOfMaterial bom)
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var dbBom = await context.BillOfMaterials.FindAsync(bom.BOMID);
        if (dbBom == null) return;
        dbBom.IsArchived = true;
        await context.SaveChangesAsync();
        await LoadData();
    }

    private async Task RestoreBOM(BillOfMaterial bom)
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var dbBom = await context.BillOfMaterials.FindAsync(bom.BOMID);
        if (dbBom == null) return;
        dbBom.IsArchived = false;
        await context.SaveChangesAsync();
        await LoadData();
    }

    private async Task ToggleArchivedView()
    {
        ShowArchived = !ShowArchived;
        await LoadData();
    }
}
