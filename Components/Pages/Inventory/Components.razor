@page "/inventory/components"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using production_system.Data
@using production_system.Models
@using Microsoft.Extensions.DependencyInjection

@attribute [Authorize(Roles = "ProductionManager,ProductionWorker,Superadmin")]
@inject IServiceScopeFactory ScopeFactory
@inject NavigationManager NavigationManager
@inject production_system.Services.FacilityFilterService FacilityFilter
@inject IJSRuntime JS

<AuthorizeView Roles="ProductionWorker">
    <Authorized>
        <PageTitle>NodeSync | Inventory Lookup</PageTitle>
    </Authorized>
    <NotAuthorized>
        <PageTitle>NodeSync | Component Inventory</PageTitle>
    </NotAuthorized>
</AuthorizeView>

<production_system.Components.Shared.FacilitySelector OnFacilityChanged="HandleFacilityChanged" />

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <AuthorizeView Roles="ProductionWorker">
            <Authorized>
                <h1 class="h3 mb-0 text-gray-800">Inventory Lookup</h1>
            </Authorized>
            <NotAuthorized>
                <h1 class="h3 mb-0 text-gray-800">Component Inventory</h1>
            </NotAuthorized>
        </AuthorizeView>
        <p class="text-muted mb-0">Manage raw materials and parts stock.</p>
    </div>
    <div class="d-flex flex-column gap-2 align-items-end">
        <button class="btn btn-outline-secondary" @onclick="ToggleArchivedView">
            <i class="bi @(ShowArchived ? "bi-eye-slash" : "bi-archive") me-1"></i>
            @(ShowArchived ? "Show Active" : "Show Archived")
        </button>
        <AuthorizeView Roles="ProductionManager">
            <Authorized>
                <button class="btn btn-primary" @onclick="OpenCreateModal" disabled="@ShowArchived">
                    <i class="bi bi-plus-lg me-1"></i> Add Component
                </button>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@if (ShowCreateModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(IsEditing ? "Edit Component" : "New Component")</h5>
                    <button type="button" class="btn-close" @onclick="CloseCreateModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="NewComponent" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Component Name <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="NewComponent.ComponentName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="NewComponent.Description" rows="3" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Unit Cost (PHP)</label>
                                <InputNumber class="form-control" @bind-Value="NewComponent.UnitCost" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Min Stock Level</label>
                                <InputNumber class="form-control" @bind-Value="NewComponent.MinStockLevel" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Supplier Info</label>
                            <InputText class="form-control" @bind-Value="NewComponent.SupplierInfo" />
                        </div>
                        
                        <div class="modal-footer px-0 pb-0">
                            <button type="button" class="btn btn-secondary" @onclick="CloseCreateModal">Cancel</button>
                             <button type="submit" class="btn btn-primary">
                                <i class="bi @(IsEditing ? "bi-check-lg" : "bi-plus-lg") me-1"></i>
                                @(IsEditing ? "Save Changes" : "Add Component")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (components == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading components...</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-box-seam me-1"></i>
                @(ShowArchived ? "Archived Components" : "Active Components")
            </span>
            <span class="badge bg-light text-dark border">@components.Where(c => c.IsArchived == ShowArchived).Count() item(s)</span>
        </div>
        <div class="card-body p-0">
            @if (!components.Where(c => c.IsArchived == ShowArchived).Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2" style="opacity: 0.3;"></i>
                    @if (ShowArchived)
                    {
                        <p>No archived components.</p>
                    }
                    else
                    {
                        <p>No components yet. Click <strong>Add Component</strong> to create one.</p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Component Name</th>
                                <th>Description</th>
                                <th>Unit Cost</th>
                                <th>Min Stock</th>
                                <th>Supplier</th>
                                <AuthorizeView Roles="ProductionManager">
                                    <Authorized>
                                        <th class="text-center" style="width: 140px;">Actions</th>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var comp in components.Where(c => c.IsArchived == ShowArchived))
                            {
                                <tr class="@(comp.IsArchived ? "table-light text-muted" : "")">
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="d-flex align-items-center justify-content-center rounded"
                                                 style="width: 32px; height: 32px; background: rgba(143,0,255,0.08); flex-shrink: 0;">
                                                <i class="bi bi-box-seam text-primary" style="font-size: 0.875rem;"></i>
                                            </div>
                                            <div>
                                                <span class="fw-bold">@comp.ComponentName</span>
                                                <div class="text-muted" style="font-size: 0.7rem;">ID: @comp.ComponentID</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-muted small">@(string.IsNullOrWhiteSpace(comp.Description) ? "â€”" : comp.Description)</td>
                                    <td>&#8369;@comp.UnitCost.ToString("N2")</td>
                                    <td><span class="badge bg-secondary">@comp.MinStockLevel</span></td>
                                    <td class="text-muted small">@(string.IsNullOrWhiteSpace(comp.SupplierInfo) ? "â€”" : comp.SupplierInfo)</td>
                                    <AuthorizeView Roles="ProductionManager">
                                        <Authorized>
                                            <td class="text-center">
                                                @if (!comp.IsArchived)
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => OpenEditModal(comp)" title="Edit">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-warning" @onclick="() => ArchiveComponent(comp)" title="Archive">
                                                        <i class="bi bi-archive"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-sm btn-outline-success" @onclick="() => RestoreComponent(comp)" title="Restore">
                                                        <i class="bi bi-arrow-counterclockwise"></i> Restore
                                                    </button>
                                                }
                                            </td>
                                        </Authorized>
                                    </AuthorizeView>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Component>? components;
    private bool ShowCreateModal = false;
    private Component NewComponent = new();
    private bool ShowArchived = false;
    private bool IsEditing = false;
    private int? userFacilityId;
    private bool isSuperAdmin;

    [Inject] private production_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();
        await LoadComponents();
    }

    private int? GetEffectiveFacilityId()
    {
        if (isSuperAdmin)
            return FacilityFilter.SelectedFacilityId;
        return userFacilityId;
    }

    private async Task HandleFacilityChanged()
    {
        await LoadComponents();
    }

    private async Task LoadComponents()
    {
        var effectiveFacilityId = GetEffectiveFacilityId();

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var query = context.Components.AsNoTracking().AsQueryable();
        if (effectiveFacilityId.HasValue)
        {
            query = query.Where(c => c.FacilityID == effectiveFacilityId.Value);
        }
        components = await query.ToListAsync();
    }

    private void ToggleArchivedView()
    {
        ShowArchived = !ShowArchived;
    }

    private void OpenCreateModal()
    {
        NewComponent = new Component();
        IsEditing = false;
        ShowCreateModal = true;
    }

    private void OpenEditModal(Component component)
    {
        NewComponent = new Component
        {
            ComponentID = component.ComponentID,
            ComponentName = component.ComponentName,
            Description = component.Description,
            UnitCost = component.UnitCost,
            MinStockLevel = component.MinStockLevel,
            SupplierInfo = component.SupplierInfo,
            IsArchived = component.IsArchived,
            FacilityID = component.FacilityID
        };
        IsEditing = true;
        ShowCreateModal = true;
    }

    private void CloseCreateModal()
    {
        ShowCreateModal = false;
    }

    private async Task HandleValidSubmit()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        
        if (IsEditing)
        {
            var existing = await context.Components.FindAsync(NewComponent.ComponentID);
            if (existing != null)
            {
                existing.ComponentName = NewComponent.ComponentName;
                existing.Description = NewComponent.Description;
                existing.UnitCost = NewComponent.UnitCost;
                existing.MinStockLevel = NewComponent.MinStockLevel;
                existing.SupplierInfo = NewComponent.SupplierInfo;
            }
        }
        else
        {
            NewComponent.FacilityID = GetEffectiveFacilityId() ?? userFacilityId;
            context.Components.Add(NewComponent);
        }

        await context.SaveChangesAsync();
        await LoadComponents();
        CloseCreateModal();
    }

    private async Task ArchiveComponent(Component component)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to archive component '{component.ComponentName}'?");
        if (!confirmed) return;

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        
        var existing = await context.Components.FindAsync(component.ComponentID);
        if (existing != null)
        {
            existing.IsArchived = true;
            await context.SaveChangesAsync();
            await LoadComponents();
        }
    }

    private async Task RestoreComponent(Component component)
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        
        var existing = await context.Components.FindAsync(component.ComponentID);
        if (existing != null)
        {
            existing.IsArchived = false;
            await context.SaveChangesAsync();
            await LoadComponents();
        }
    }
}

