@page "/inventory/transactions"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using manufacturing_system.Data
@using manufacturing_system.Models

@attribute [Authorize(Roles = "ProductionManager,Superadmin")]
@inject IServiceScopeFactory ScopeFactory

<PageTitle>NodeSync | Stock Transactions</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Stock Transactions</h1>
        <p class="text-muted mb-0">Track history of stock movements.</p>
    </div>
</div>

@if (transactions == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading transactions...</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-arrow-left-right me-1"></i> Transaction History</span>
            <span class="badge bg-light text-dark border">@transactions.Count record(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Date</th>
                            <th>Type</th>
                            <th>Component</th>
                            <th>Qty</th>
                            <th>User</th>
                            <th>Reference</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var txn in transactions)
                        {
                            <tr>
                                <td class="ps-4">@txn.TransactionDate.ToString("g")</td>
                                <td>
                                    <span class="badge @GetBadgeClass(txn.TransactionType)">@txn.TransactionType</span>
                                </td>
                                <td class="fw-bold">@txn.Component?.ComponentName</td>
                                <td class="@GetQtyClass(txn.TransactionType)">
                                    @txn.Quantity
                                </td>
                                <td class="text-muted small">@txn.User?.UserName</td>
                                <td class="text-muted small">
                                    @if (txn.OrderID != null)
                                    {
                                        <span>Order #@txn.OrderID</span>
                                    }
                                    else
                                    {
                                        <span>Manual</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<InventoryTransaction>? transactions;
    private int? userFacilityId;
    private bool isSuperAdmin;

    [Inject] private manufacturing_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();

        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var query = context.InventoryTransactions
            .Include(t => t.Component)
            .Include(t => t.User)
            .AsQueryable();

        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            query = query.Where(t => t.FacilityID == userFacilityId.Value);
        }

        transactions = await query
            .OrderByDescending(t => t.TransactionDate)
            .ToListAsync();
    }

    private string GetBadgeClass(string type) => type switch
    {
        "Inbound" => "bg-success",
        "Outbound" => "bg-danger",
        "Adjustment" => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    private string GetQtyClass(string type) => type == "Inbound" ? "text-success fw-bold" : "text-danger fw-bold";
}
