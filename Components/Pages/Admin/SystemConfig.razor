@page "/admin/system-config"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using production_system.Data
@using production_system.Models

@attribute [Authorize(Roles = "Superadmin")]
@inject IConfiguration Configuration
@inject IServiceScopeFactory ScopeFactory
@rendermode InteractiveServer

<PageTitle>NodeSync | System Configuration</PageTitle>

<div class="row mb-4">
    <div class="col-md-6">
        <h1 class="h3 mb-0 text-gray-800">System Configuration</h1>
        <p class="text-muted">View system settings and connection information.</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="alert @statusAlertClass alert-dismissible fade show" role="alert">
        <i class="bi @statusIcon me-2"></i>@statusMessage
        <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
    </div>
}

<!-- App Info -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-app-indicator fs-1 text-primary"></i>
                <h5 class="card-title mt-2">Application</h5>
                <p class="mb-0 fw-bold">NodeSync</p>
                <small class="text-muted">Integrated Production System</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-hdd-rack fs-1 text-info"></i>
                <h5 class="card-title mt-2">Environment</h5>
                <p class="mb-0 fw-bold">@environment</p>
                <small class="text-muted">Runtime environment</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="bi bi-building fs-1 text-success"></i>
                <h5 class="card-title mt-2">Facilities</h5>
                <p class="mb-0 fw-bold">@facilityCount</p>
                <small class="text-muted">Registered facilities</small>
            </div>
        </div>
    </div>
</div>

<!-- Connection String (masked) -->
<div class="card shadow mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-plug me-2"></i>Database Connection</h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label fw-bold">Connection String</label>
            <div class="input-group">
                <input type="@(showConnectionString ? "text" : "password")" class="form-control font-monospace" value="@connectionString" readonly />
                <button class="btn btn-outline-secondary" @onclick="() => showConnectionString = !showConnectionString">
                    <i class="bi @(showConnectionString ? "bi-eye-slash" : "bi-eye")"></i>
                </button>
            </div>
            <div class="form-text">Read-only. Update in <code>appsettings.json</code> and restart the app.</div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Server</label>
                <input type="text" class="form-control" value="@dbServer" readonly />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Database</label>
                <input type="text" class="form-control" value="@dbCatalog" readonly />
            </div>
        </div>
    </div>
</div>

<!-- API Keys Management -->
<div class="card shadow mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-key me-2"></i>API Keys Management</h5>
    </div>
    <div class="card-body">
        <p class="text-muted small mb-4">Configure OpenWeather and Exchange Rate API keys for each facility. These keys are used for environment monitoring and currency conversion respectively.</p>

        @foreach (var f in facilities)
        {
            var facilityId = f.FacilityID;
            var isExpanded = expandedFacility == facilityId;
            var hasWeather = !string.IsNullOrEmpty(f.APIKeyOpenWeather);
            var hasExchange = !string.IsNullOrEmpty(f.APIKeyExchangeRate);
            var statusBadge = (hasWeather && hasExchange) ? "bg-success" : (hasWeather || hasExchange) ? "bg-warning text-dark" : "bg-secondary";
            var statusText = (hasWeather && hasExchange) ? "Configured" : (hasWeather || hasExchange) ? "Partial" : "Not configured";

            <div class="api-key-facility-card mb-3">
                <div class="api-key-facility-header" @onclick="() => ToggleFacility(facilityId)">
                    <div class="d-flex align-items-center gap-3">
                        <div class="api-key-facility-icon">
                            <i class="bi bi-building"></i>
                        </div>
                        <div>
                            <strong>@f.FacilityName</strong>
                            <div class="text-muted" style="font-size: 0.75rem;">@(f.Location ?? "No location")</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge @statusBadge">@statusText</span>
                        <i class="bi @(isExpanded ? "bi-chevron-up" : "bi-chevron-down") text-muted"></i>
                    </div>
                </div>

                @if (isExpanded)
                {
                    <div class="api-key-facility-body">
                        @{ var weatherType = "weather"; var exchangeType = "exchange"; }
                        <div class="row g-3">
                            <!-- OpenWeather API Key -->
                            <div class="col-md-6">
                                <label class="form-label fw-bold d-flex align-items-center gap-2">
                                    <i class="bi bi-cloud-sun text-info"></i> OpenWeather API Key
                                </label>
                                <div class="input-group">
                                    <input type="@(IsKeyVisible(facilityId, weatherType) ? "text" : "password")"
                                           class="form-control font-monospace"
                                           value="@f.APIKeyOpenWeather"
                                           @oninput="(e) => UpdateWeatherKey(facilityId, e.Value?.ToString())"
                                           placeholder="Enter OpenWeather API key..." />
                                    <button class="btn btn-outline-secondary" type="button"
                                            @onclick="() => ToggleKeyVisibility(facilityId, weatherType)">
                                        <i class="bi @(IsKeyVisible(facilityId, weatherType) ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                </div>
                                <div class="form-text">
                                    <i class="bi bi-info-circle me-1"></i>Used for temperature & humidity monitoring.
                                    @if (hasWeather)
                                    {
                                        <span class="text-success ms-1"><i class="bi bi-check-circle"></i> Active</span>
                                    }
                                </div>
                            </div>

                            <!-- Exchange Rate API Key -->
                            <div class="col-md-6">
                                <label class="form-label fw-bold d-flex align-items-center gap-2">
                                    <i class="bi bi-currency-exchange text-primary"></i> Exchange Rate API Key
                                </label>
                                <div class="input-group">
                                    <input type="@(IsKeyVisible(facilityId, exchangeType) ? "text" : "password")"
                                           class="form-control font-monospace"
                                           value="@f.APIKeyExchangeRate"
                                           @oninput="(e) => UpdateExchangeKey(facilityId, e.Value?.ToString())"
                                           placeholder="Enter Exchange Rate API key..." />
                                    <button class="btn btn-outline-secondary" type="button"
                                            @onclick="() => ToggleKeyVisibility(facilityId, exchangeType)">
                                        <i class="bi @(IsKeyVisible(facilityId, exchangeType) ? "bi-eye-slash" : "bi-eye")"></i>
                                    </button>
                                </div>
                                <div class="form-text">
                                    <i class="bi bi-info-circle me-1"></i>Used for live USD &rarr; PHP currency conversion.
                                    @if (hasExchange)
                                    {
                                        <span class="text-success ms-1"><i class="bi bi-check-circle"></i> Active</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-3 pt-3 border-top">
                            @if (savedFacilityId == facilityId)
                            {
                                <span class="text-success d-flex align-items-center me-2">
                                    <i class="bi bi-check-circle-fill me-1"></i> Saved!
                                </span>
                            }
                            <button class="btn btn-primary" @onclick="() => SaveFacilityKeys(facilityId)">
                                <i class="bi bi-save me-1"></i> Save Keys
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Global Settings from appsettings.json -->
<div class="card shadow mb-4">
    <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Global API Settings</h5>
    </div>
    <div class="card-body">
        <p class="text-muted small">These are the global fallback API settings from <code>appsettings.json</code>. They are read-only here.</p>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">OpenWeather Base URL</label>
                <input type="text" class="form-control" value="@openWeatherBaseUrl" readonly />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Exchange Rate Base URL</label>
                <input type="text" class="form-control" value="@exchangeRateBaseUrl" readonly />
            </div>
        </div>
    </div>
</div>

<style>
    .api-key-facility-card {
        border: 1px solid var(--ns-border);
        border-radius: 0.5rem;
        overflow: hidden;
        transition: border-color 0.15s ease;
    }

    .api-key-facility-card:hover {
        border-color: var(--ns-primary-light);
    }

    .api-key-facility-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.875rem 1rem;
        cursor: pointer;
        background: #fafbfc;
        transition: background 0.15s ease;
    }

    .api-key-facility-header:hover {
        background: #f0f1f3;
    }

    .api-key-facility-icon {
        width: 36px;
        height: 36px;
        border-radius: 0.5rem;
        background: rgba(143, 0, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ns-primary);
        font-size: 1rem;
        flex-shrink: 0;
    }

    .api-key-facility-body {
        padding: 1rem;
        border-top: 1px solid var(--ns-border);
        animation: fadeIn 0.2s ease-out;
    }
</style>

@code {
    private string? statusMessage;
    private string statusAlertClass = "alert-info";
    private string statusIcon = "bi-info-circle";

    private string environment = "Unknown";
    private int facilityCount = 0;
    private string connectionString = "";
    private string dbServer = "";
    private string dbCatalog = "";
    private bool showConnectionString = false;
    private string openWeatherBaseUrl = "";
    private string exchangeRateBaseUrl = "";
    private List<Facility> facilities = new();

    // API Key management state
    private int? expandedFacility;
    private int? savedFacilityId;
    private HashSet<string> visibleKeys = new();

    protected override async Task OnInitializedAsync()
    {
        // Environment
        environment = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") ?? "Production";

        // Connection info
        var connectionStringName = environment == "Development" ? "DefaultConnection" : "OnlineConnection";
        connectionString = Configuration.GetConnectionString(connectionStringName) ?? Configuration.GetConnectionString("DefaultConnection") ?? "Not configured";
        ParseConnectionString();

        // API settings from appsettings
        openWeatherBaseUrl = Configuration["ApiSettings:OpenWeatherBaseUrl"] ?? "Not set";
        exchangeRateBaseUrl = Configuration["ApiSettings:ExchangeRateBaseUrl"] ?? "Not set";

        // Facilities
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        facilities = await context.Facilities.ToListAsync();
        facilityCount = facilities.Count;
    }

    private void ToggleFacility(int facilityId)
    {
        expandedFacility = expandedFacility == facilityId ? null : facilityId;
        savedFacilityId = null;
    }

    private string GetVisibilityKey(int facilityId, string keyType) => $"{facilityId}_{keyType}";

    private bool IsKeyVisible(int facilityId, string keyType) =>
        visibleKeys.Contains(GetVisibilityKey(facilityId, keyType));

    private void ToggleKeyVisibility(int facilityId, string keyType)
    {
        var vk = GetVisibilityKey(facilityId, keyType);
        if (!visibleKeys.Remove(vk))
            visibleKeys.Add(vk);
    }

    private void UpdateWeatherKey(int facilityId, string? value)
    {
        var facility = facilities.FirstOrDefault(f => f.FacilityID == facilityId);
        if (facility != null) facility.APIKeyOpenWeather = value;
    }

    private void UpdateExchangeKey(int facilityId, string? value)
    {
        var facility = facilities.FirstOrDefault(f => f.FacilityID == facilityId);
        if (facility != null) facility.APIKeyExchangeRate = value;
    }

    private async Task SaveFacilityKeys(int facilityId)
    {
        var facility = facilities.FirstOrDefault(f => f.FacilityID == facilityId);
        if (facility == null) return;

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
            var dbFacility = await context.Facilities.FindAsync(facilityId);
            if (dbFacility != null)
            {
                dbFacility.APIKeyOpenWeather = facility.APIKeyOpenWeather;
                dbFacility.APIKeyExchangeRate = facility.APIKeyExchangeRate;
                await context.SaveChangesAsync();
            }

            savedFacilityId = facilityId;
            statusMessage = $"API keys for {facility.FacilityName} saved successfully.";
            statusAlertClass = "alert-success";
            statusIcon = "bi-check-circle-fill";

            // Auto-dismiss after 3s
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                await InvokeAsync(() =>
                {
                    savedFacilityId = null;
                    statusMessage = null;
                    StateHasChanged();
                });
            });
        }
        catch (Exception ex)
        {
            statusMessage = $"Error saving keys: {ex.Message}";
            statusAlertClass = "alert-danger";
            statusIcon = "bi-exclamation-triangle-fill";
        }
    }

    private void ParseConnectionString()
    {
        try
        {
            var parts = connectionString.Split(';', StringSplitOptions.RemoveEmptyEntries);
            foreach (var part in parts)
            {
                var kv = part.Split('=', 2);
                if (kv.Length != 2) continue;
                var key = kv[0].Trim().ToLower();
                var val = kv[1].Trim();

                if (key == "server" || key == "data source")
                    dbServer = val;
                else if (key == "database" || key == "initial catalog")
                    dbCatalog = val;
            }
        }
        catch
        {
            dbServer = "Unknown";
            dbCatalog = "Unknown";
        }
    }

    private string MaskKey(string key)
    {
        if (string.IsNullOrEmpty(key) || key.Length <= 6) return "••••••";
        return key[..3] + "••••••" + key[^3..];
    }
}

