@page "/admin/logs"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using production_system.Data
@using production_system.Models

@attribute [Authorize(Roles = "Superadmin,Administrator")]
@inject IServiceScopeFactory ScopeFactory
@inject UserManager<ApplicationUser> UserManager

<PageTitle>NodeSync | Audit Logs</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0 text-gray-800">Audit Logs</h1>
        <p class="text-muted mb-0">Audit system actions and user activity.</p>
    </div>
</div>

@if (logs == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading logs...</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-clock-history me-1"></i> Recent Activity</span>
            <span class="badge bg-light text-dark border">@logs.Count record(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Time</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Details</th>
                            <th>IP Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs)
                        {
                            <tr>
                                <td class="ps-4 text-nowrap">@log.Timestamp.ToString("g")</td>
                                <td>
                                    <div class="fw-bold">@log.User?.UserName</div>
                                    <div class="small text-muted">@GetUserRole(log.UserID)</div>
                                </td>
                                <td><span class="badge bg-secondary text-light">@log.ActionType</span></td>
                                <td>@log.Details</td>
                                <td class="text-muted small">@log.IPAddress</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private List<ActivityLog>? logs;
    private Dictionary<string, string> userRoles = new();
    private int? userFacilityId;
    private bool isSuperAdmin;

    [Inject] private production_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var query = context.ActivityLogs
            .Include(l => l.User)
            .OrderByDescending(l => l.Timestamp)
            .AsQueryable();

        if (!isSuperAdmin && userFacilityId.HasValue)
        {
            query = query.Where(l => l.FacilityID == userFacilityId.Value);
        }

        logs = await query
            .Take(100)
            .ToListAsync();
        
        // Load roles for all users in the logs
        var userIds = logs.Where(l => l.UserID != null).Select(l => l.UserID).Distinct();
        foreach (var userId in userIds)
        {
            var user = await UserManager.FindByIdAsync(userId!);
            if (user != null)
            {
                var roles = await UserManager.GetRolesAsync(user);
                userRoles[userId!] = roles.FirstOrDefault() ?? "";
            }
        }
    }
    
    private string GetUserRole(string? userId)
    {
        if (string.IsNullOrEmpty(userId)) return "";
        return userRoles.GetValueOrDefault(userId, "");
    }
}

