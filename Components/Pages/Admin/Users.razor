@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using manufacturing_system.Data
@using manufacturing_system.Models

@attribute [Authorize(Roles = "Superadmin,Administrator,ProductionManager")]
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject manufacturing_system.Services.FacilityAccessService FacilityAccess

@using System.Security.Claims

<PageTitle>NodeSync | @(IsManager ? "User Directory" : "User Management")</PageTitle>

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-0 text-gray-800">@(IsManager ? "User Directory" : "User Management")</h1>
        <p class="text-muted mb-0">@(IsManager ? "View active users and their assigned facilities." : "Manage user roles, access, and status.")</p>
    </div>
    @if (!IsManager)
    {
        <div>
            <button class="btn btn-primary px-4 py-2" style="width: auto;" @onclick="OpenAddModal">
                <i class="bi bi-person-plus me-1"></i> Add User
            </button>
        </div>
    }
</div>

@if (!IsManager && ShowAddModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add New User</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(addErrorMessage))
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-1"></i> @addErrorMessage
                        </div>
                    }
                    <EditForm Model="NewUser" OnValidSubmit="HandleAddSubmit">
                        <DataAnnotationsValidator />
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">First Name *</label>
                                <InputText class="form-control" @bind-Value="NewUser.FirstName" required />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Middle Name</label>
                                <InputText class="form-control" @bind-Value="NewUser.MiddleName" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Last Name *</label>
                                <InputText class="form-control" @bind-Value="NewUser.LastName" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email Address *</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <InputText type="email" class="form-control" @bind-Value="NewUser.Email" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Temporary Password *</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-key"></i></span>
                                <InputText class="form-control" @bind-Value="NewUser.Password" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Role *</label>
                            <select class="form-select" @bind="NewUser.Role" required>
                                @if (!IsAdmin)
                                {
                                    <option value="Superadmin">Superadmin</option>
                                    <option value="Administrator">Administrator</option>
                                }
                                <option value="ProductionManager">Production Manager</option>
                                <option value="ProductionWorker">Production Worker</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Assigned Facility</label>
                            @if (!IsAdmin)
                            {
                                <select class="form-select" @bind="NewUser.FacilityID">
                                    <option value="">-- None --</option>
                                    @foreach (var f in facilities)
                                    {
                                        <option value="@f.FacilityID">@f.FacilityName</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input class="form-control" value="@(adminFacilityName ?? "None")" disabled />
                            }
                        </div>

                        <div class="modal-footer px-0 pb-0 d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-secondary" @onclick="CloseAddModal">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                }
                                Create User
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (!IsManager && ShowEditModal && EditingUserModel != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit User: @EditingUserModel.Email</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="EditingUserModel" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">First Name</label>
                                <InputText class="form-control" @bind-Value="EditingUserModel.FirstName" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Middle Name</label>
                                <InputText class="form-control" @bind-Value="EditingUserModel.MiddleName" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Last Name</label>
                                <InputText class="form-control" @bind-Value="EditingUserModel.LastName" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <InputText class="form-control" @bind-Value="EditingUserModel.Email" />
                            </div>
                            <div class="form-text text-muted">Changing this updates the user's login identity.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText class="form-control" @bind-Value="EditingUserModel.PhoneNumber" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Role</label>
                            <select class="form-select" @bind="SelectedRole" disabled="@(IsAdmin && GetUserRole(EditingUserModel.Id) == "Superadmin")">
                                @if (!IsAdmin)
                                {
                                    <option value="Superadmin">Superadmin</option>
                                }
                                <option value="Administrator">Administrator</option>
                                <option value="ProductionManager">Production Manager</option>
                                <option value="ProductionWorker">Production Worker</option>
                            </select>
                            <div class="form-text">Changing this will update the user's system role.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Assigned Facility</label>
                            @if (!IsAdmin)
                            {
                                <select class="form-select" @bind="EditingUserModel.FacilityID">
                                    <option value="">-- None --</option>
                                    @foreach (var f in facilities)
                                    {
                                        <option value="@f.FacilityID">@f.FacilityName</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input class="form-control" value="@(EditingUserModel.FacilityName ?? "None")" disabled />
                            }
                        </div>

                        <div class="form-check form-switch mb-3">
                            <InputCheckbox class="form-check-input" @bind-Value="EditingUserModel.IsArchived" id="archiveSwitch" disabled="@(EditingUserModel.Id == currentUserId)" />
                            <label class="form-check-label" for="archiveSwitch">
                                Archive User (Disable Access)
                                @if(EditingUserModel.Id == currentUserId)
                                {
                                    <span class="text-danger small ms-2">(Cannot archive yourself)</span>
                                }
                            </label>
                        </div>

                        <div class="modal-footer px-0 pb-0 d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-warning btn-sm" @onclick="() => ShowResetConfirm(EditingUserModel.Id)" title="Reset password to temporary">
                                <i class="bi bi-key me-1"></i> Reset Password
                            </button>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-secondary" @onclick="CloseEditModal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save Changes</button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (!IsManager && ShowResetPasswordModal && ResetTargetUser != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reset Password</h5>
                    <button type="button" class="btn-close" @onclick="CloseResetModal"></button>
                </div>
                <div class="modal-body">
                    @if (string.IsNullOrEmpty(resetResultMessage))
                    {
                        <p class="mb-2">Reset password for <strong>@ResetTargetUser.UserName</strong>?</p>
                        <p class="text-muted small mb-0">The password will be set to:</p>
                        <div class="bg-light rounded p-2 mt-1 text-center">
                            <code class="fs-6">NodeSync2026!</code>
                        </div>
                    }
                    else
                    {
                        <div class="alert @(resetResultMessage.StartsWith("Error") ? "alert-danger" : "alert-success") mb-0">
                            <i class="bi @(resetResultMessage.StartsWith("Error") ? "bi-exclamation-triangle" : "bi-check-circle") me-1"></i>
                            @resetResultMessage
                        </div>
                        @if (!resetResultMessage.StartsWith("Error"))
                        {
                            <div class="bg-light rounded p-2 mt-2 text-center">
                                <span class="small text-muted">Temporary password:</span><br/>
                                <code class="fs-6">NodeSync2026!</code>
                            </div>
                            <p class="text-muted small mt-2 mb-0">Instruct the user to change this password upon login.</p>
                        }
                    }
                </div>
                <div class="modal-footer">
                    @if (string.IsNullOrEmpty(resetResultMessage))
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CloseResetModal">Cancel</button>
                        <button type="button" class="btn btn-warning" @onclick="ExecutePasswordReset">
                            <i class="bi bi-key me-1"></i> Confirm Reset
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CloseResetModal">Close</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (users == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading users...</p>
    </div>
}
else
{
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-people me-1"></i> System Users</span>
            <span class="badge bg-light text-dark border">@users.Count user(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Facility</th>
                            <th>Status</th>
                            @if (!IsManager)
                            {
                                <th class="text-center" style="width: 160px;">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in users)
                        {
                            <tr class="@(user.IsArchived ? "table-secondary text-muted" : "")">
                                <td class="ps-4">
                                    <div class="fw-bold">@user.FirstName @user.LastName</div>
                                    <div class="small text-muted">@user.UserName</div>
                                </td>
                                <td>@user.Email</td>
                                <td><span class="badge bg-info text-dark">@GetReadableRole(GetUserRole(user.Id))</span></td>
                                <td>@(user.Facility?.FacilityName ?? "None")</td>
                                <td>
                                    @if (user.IsArchived)
                                    {
                                        <span class="badge bg-secondary">Archived</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                </td>
                                @if (!IsManager)
                                {
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditUser(user)" disabled="@(IsAdmin && GetUserRole(user.Id) == "Superadmin")" title="Edit user">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => ShowResetConfirm(user.Id)" disabled="@(IsAdmin && GetUserRole(user.Id) == "Superadmin")" title="Reset password">
                                                <i class="bi bi-key"></i>
                                            </button>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private class AddUserForm
    {
        public string FirstName { get; set; } = "";
        public string? MiddleName { get; set; }
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "NodeSync2026!";
        public string Role { get; set; } = "ProductionWorker";
        public int? FacilityID { get; set; }
    }

    private class EditUserForm
    {
        public string Id { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string? MiddleName { get; set; }
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string PhoneNumber { get; set; } = "";
        public int? FacilityID { get; set; }
        public string? FacilityName { get; set; }
        public bool IsArchived { get; set; }
    }

    private AddUserForm NewUser = new();
    private EditUserForm? EditingUserModel;
    private bool ShowAddModal = false;
    private string? addErrorMessage;
    private bool isSubmitting = false;

    private int? adminFacilityId;
    private string? adminFacilityName;

    private List<ApplicationUser>? users;
    private Dictionary<string, string> userRoles = new(); // UserId -> RoleName
    private List<Facility> facilities = new();
    private bool ShowEditModal = false;
    private bool ShowResetPasswordModal = false;
    private ApplicationUser? ResetTargetUser;
    private string SelectedRole = "";
    private string? currentUserId;
    private bool IsAdmin => currentUserRole == "Administrator";
    private bool IsManager => currentUserRole == "ProductionManager";
    private string? currentUserRole;
    private string? resetResultMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        currentUserRole = user.IsInRole("Superadmin") ? "Superadmin" 
            : user.IsInRole("Administrator") ? "Administrator" 
            : user.IsInRole("ProductionManager") ? "ProductionManager" 
            : "";
        
        await LoadData();
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();

        // 1. Get current user's facility info FIRST for filtering
        if (string.IsNullOrEmpty(currentUserId)) return;
        
        var profile = await context.Users.Include(u => u.Facility).AsNoTracking().FirstOrDefaultAsync(u => u.Id == currentUserId);
        adminFacilityId = profile?.FacilityID;
        adminFacilityName = profile?.Facility?.FacilityName;

        // 2. Load and filter user list
        facilities = await context.Facilities.AsNoTracking().ToListAsync();
        
        var query = context.Users.Include(u => u.Facility).AsNoTracking();
        
        // Filter: Admin and Manager ONLY see their own facility + ALL Superadmins. Superadmin sees everyone.
        if (currentUserRole != "Superadmin")
        {
            // Get Superadmin IDs to include them regardless of facility
            var superAdminRole = await context.Roles.AsNoTracking().FirstOrDefaultAsync(r => r.Name == "Superadmin");
            var superAdminIds = new List<string>();
            if (superAdminRole != null)
            {
                superAdminIds = await context.UserRoles.AsNoTracking()
                    .Where(ur => ur.RoleId == superAdminRole.Id)
                    .Select(ur => ur.UserId)
                    .ToListAsync();
            }

            if (adminFacilityId.HasValue)
            {
                query = query.Where(u => u.FacilityID == adminFacilityId.Value || superAdminIds.Contains(u.Id));
            }
            else
            {
                // Edge case: Admin has no facility? They only see Superadmins (security first)
                query = query.Where(u => superAdminIds.Contains(u.Id));
            }
        }

        var userList = await query.ToListAsync();
        
        // 3. Load roles for all users in the filtered list
        var rolesDict = new Dictionary<string, string>();
        foreach (var user in userList)
        {
            var roles = await userManager.GetRolesAsync(user);
            rolesDict[user.Id] = roles.FirstOrDefault() ?? "";
        }

        // Update state in one go
        users = userList;
        userRoles = rolesDict;
    }

    private void OpenAddModal()
    {
        NewUser = new AddUserForm();
        if (IsAdmin) NewUser.FacilityID = adminFacilityId;
        addErrorMessage = null;
        ShowAddModal = true;
    }

    private void CloseAddModal()
    {
        ShowAddModal = false;
    }

    private async Task HandleAddSubmit()
    {
        isSubmitting = true;
        addErrorMessage = null;
        StateHasChanged();

        try
        {
            using var scope = ScopeFactory.CreateScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            
            var existingUser = await userManager.FindByEmailAsync(NewUser.Email);
            if (existingUser != null)
            {
                addErrorMessage = "A user with this email already exists.";
                isSubmitting = false;
                return;
            }

            var user = new ApplicationUser
            {
                UserName = NewUser.Email,
                Email = NewUser.Email,
                FirstName = NewUser.FirstName,
                MiddleName = NewUser.MiddleName,
                LastName = NewUser.LastName,
                FacilityID = IsAdmin ? adminFacilityId : NewUser.FacilityID,
                EmailConfirmed = true
            };

            var result = await userManager.CreateAsync(user, NewUser.Password);
            if (result.Succeeded)
            {
                await userManager.AddToRoleAsync(user, NewUser.Role);
                await LoadData();
                CloseAddModal();
            }
            else
            {
                addErrorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
            }
        }
        catch (Exception ex)
        {
            addErrorMessage = "Error creating user: " + ex.Message;
        }

        isSubmitting = false;
        StateHasChanged();
    }

    private async Task EditUser(ApplicationUser user)
    {
        var userRole = userRoles.GetValueOrDefault(user.Id, "");
        if (IsAdmin && userRole == "Superadmin") return; // Admin cannot edit Superadmin

        EditingUserModel = new EditUserForm
        {
            Id = user.Id,
            FirstName = user.FirstName,
            MiddleName = user.MiddleName,
            LastName = user.LastName,
            Email = user.Email ?? "",
            PhoneNumber = user.PhoneNumber ?? "",
            FacilityID = user.FacilityID,
            FacilityName = user.Facility?.FacilityName,
            IsArchived = user.IsArchived
        };

        SelectedRole = userRole; // Initialize with current role from AspNetUserRoles
        if (string.IsNullOrEmpty(SelectedRole)) SelectedRole = "ProductionWorker"; // Default
        ShowEditModal = true;
    }

    private void CloseEditModal()
    {
        ShowEditModal = false;
        EditingUserModel = null;
    }

    private async Task HandleValidSubmit()
    {
        if (EditingUserModel == null) return;

        using var scope = ScopeFactory.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();

        // 1. Update basic properties
        var user = await userManager.FindByIdAsync(EditingUserModel.Id);
        if (user == null) return;

        bool wasArchived = user.IsArchived;

        user.FirstName = EditingUserModel.FirstName;
        user.MiddleName = EditingUserModel.MiddleName;
        user.LastName = EditingUserModel.LastName;
        user.PhoneNumber = EditingUserModel.PhoneNumber;
        user.FacilityID = EditingUserModel.FacilityID;
        user.IsArchived = EditingUserModel.IsArchived;

        // Force logout if archived
        if (!wasArchived && user.IsArchived)
        {
            await userManager.UpdateSecurityStampAsync(user);
        }

        // Update email if changed
        if (!string.IsNullOrEmpty(EditingUserModel.Email) && EditingUserModel.Email != user.Email)
        {
            var token = await userManager.GenerateChangeEmailTokenAsync(user, EditingUserModel.Email);
            await userManager.ChangeEmailAsync(user, EditingUserModel.Email, token);
            await userManager.SetUserNameAsync(user, EditingUserModel.Email);
        }
        
        // 2. Update Role in AspNetUserRoles
        var currentRole = userRoles.GetValueOrDefault(user.Id, "");
        if (currentRole != SelectedRole)
        {
            // Remove from old role
            if (!string.IsNullOrEmpty(currentRole))
            {
                await userManager.RemoveFromRoleAsync(user, currentRole);
            }
            
            // Add to new role
            await userManager.AddToRoleAsync(user, SelectedRole);
        }

        await userManager.UpdateAsync(user);
        
        await LoadData();
        CloseEditModal();
    }
    
    private string GetReadableRole(string role)
    {
        return role switch
        {
            "Superadmin" or "SuperAdministrator" => "Super Administrator",
            "ProductionManager" => "Production Manager",
            "ProductionWorker" => "Production Worker",
            _ => role
        };
    }
    
    private string GetUserRole(string userId)
    {
        return userRoles.GetValueOrDefault(userId, "");
    }

    private void ShowResetConfirm(string userId)
    {
        var user = users?.FirstOrDefault(u => u.Id == userId);
        if (user != null)
        {
            ResetTargetUser = user;
            resetResultMessage = null;
            ShowResetPasswordModal = true;
        }
    }

    private void CloseResetModal()
    {
        ShowResetPasswordModal = false;
        ResetTargetUser = null;
        resetResultMessage = null;
    }

    private async Task ExecutePasswordReset()
    {
        if (ResetTargetUser == null) return;

        using var scope = ScopeFactory.CreateScope();
        var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
        var user = await userManager.FindByIdAsync(ResetTargetUser.Id);
        if (user == null)
        {
            resetResultMessage = "Error: User not found.";
            return;
        }

        // Remove existing password and set temporary one
        var removeResult = await userManager.RemovePasswordAsync(user);
        if (!removeResult.Succeeded)
        {
            resetResultMessage = $"Error: {string.Join(", ", removeResult.Errors.Select(e => e.Description))}";
            return;
        }

        var addResult = await userManager.AddPasswordAsync(user, "NodeSync2026!");
        if (!addResult.Succeeded)
        {
            resetResultMessage = $"Error: {string.Join(", ", addResult.Errors.Select(e => e.Description))}";
            return;
        }

        resetResultMessage = $"Password for {user.UserName} has been reset successfully.";
    }
}
