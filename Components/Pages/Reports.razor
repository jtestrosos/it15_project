@page "/reports"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using production_system.Data
@using production_system.Models

@attribute [Authorize(Roles = "ProductionManager,Administrator,Superadmin")]
@inject IServiceScopeFactory ScopeFactory
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>NodeSync | Reports & Analytics</PageTitle>

<!-- Report Header -->
<div class="rpt-header">
    <div class="rpt-header-content">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <div class="rpt-header-icon">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <div>
                    <h1 class="h3 mb-0 fw-bold">Reports &amp; Analytics</h1>
                    <p>Live operational data across production, inventory &amp; costs</p>
                </div>
            </div>
            <div class="rpt-filters">
                <div class="rpt-filter-group">
                    <span class="rpt-filter-label">From</span>
                    <input type="date" class="rpt-filter-input"
                           @bind="FilterFrom" @bind:event="oninput" @onchange="ApplyFilters" />
                </div>
                <div class="rpt-filter-group">
                    <span class="rpt-filter-label">To</span>
                    <input type="date" class="rpt-filter-input"
                           @bind="FilterTo" @bind:event="oninput" @onchange="ApplyFilters" />
                </div>
                <button class="rpt-print-btn" @onclick="PrintReport">
                    <i class="bi bi-printer"></i> Print
                </button>
            </div>
        </div>
    </div>
</div>

@if (IsLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-3 text-muted">Loading report dataâ€¦</p>
    </div>
}
else
{
    <!-- Tab Navigation -->
    <div class="rpt-tabs mb-4">
        <button class="rpt-tab @(ActiveTab == "production" ? "active" : "")"
                @onclick='() => ActiveTab = "production"'>
            <i class="bi bi-clipboard-data"></i> Production
        </button>
        <button class="rpt-tab @(ActiveTab == "workorders" ? "active" : "")"
                @onclick='() => ActiveTab = "workorders"'>
            <i class="bi bi-list-task"></i> Work Orders
        </button>
        <button class="rpt-tab @(ActiveTab == "inventory" ? "active" : "")"
                @onclick='() => ActiveTab = "inventory"'>
            <i class="bi bi-box-seam"></i> Inventory
        </button>
        <button class="rpt-tab @(ActiveTab == "costs" ? "active" : "")"
                @onclick='() => ActiveTab = "costs"'>
            <i class="bi bi-currency-dollar"></i> Costs
        </button>
    </div>

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         TAB: PRODUCTION
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    @if (ActiveTab == "production")
    {
        <div class="rpt-section">
        <!-- KPI Row -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-purple">
                    <div class="rpt-kpi-icon"><i class="bi bi-clipboard-data"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredPlans.Count</div>
                        <div class="rpt-kpi-label">Total Plans</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-green">
                    <div class="rpt-kpi-icon"><i class="bi bi-check-circle"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredPlans.Count(p => p.Status == "Active")</div>
                        <div class="rpt-kpi-label">Active Plans</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-amber">
                    <div class="rpt-kpi-icon"><i class="bi bi-pencil-square"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredPlans.Count(p => p.Status == "Draft")</div>
                        <div class="rpt-kpi-label">Draft Plans</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-blue">
                    <div class="rpt-kpi-icon"><i class="bi bi-boxes"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredPlans.Sum(p => p.BatchQuantity).ToString("N0")</div>
                        <div class="rpt-kpi-label">Total Units Planned</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart.js: Production by Product -->
        <div class="rpt-chart-card mb-4">
            <div class="rpt-chart-header">
                <span class="rpt-chart-title"><i class="bi bi-bar-chart-line"></i> Production by Product</span>
                <span class="badge bg-light text-dark border">@FilteredPlans.Count records</span>
            </div>
            <div class="rpt-chart-body">
                @if (!FilteredPlans.Any())
                {
                    <div class="rpt-empty"><i class="bi bi-bar-chart"></i>No production plans in selected range.</div>
                }
                else
                {
                    <div style="position:relative; height:300px;">
                        <canvas id="productionBarChart"></canvas>
                    </div>
                }
            </div>
        </div>

        <!-- Plans Table -->
        <div class="rpt-table-card">
            <div class="rpt-table-header">
                <span class="rpt-table-title"><i class="bi bi-table"></i> Production Plan Details</span>
                <span class="badge bg-light text-dark border">@FilteredPlans.Count total</span>
            </div>
            <div style="padding: 0;">
                @if (!FilteredPlans.Any())
                {
                    <div class="rpt-empty"><i class="bi bi-inbox"></i>No records found.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">#</th>
                                    <th>Product</th>
                                    <th>Qty</th>
                                    <th>Start</th>
                                    <th>End</th>
                                    <th>Status</th>
                                    <th>Created By</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in FilteredPlans)
                                {
                                    <tr>
                                        <td class="text-muted small ps-3">@p.PlanID</td>
                                        <td class="fw-500">@(p.Product?.ProductName ?? "â€”")</td>
                                        <td>@p.BatchQuantity.ToString("N0")</td>
                                        <td>@p.PlannedStartDate.ToString("MMM d, yyyy")</td>
                                        <td>@p.PlannedEndDate.ToString("MMM d, yyyy")</td>
                                        <td><span class="badge @GetPlanBadge(p.Status)">@p.Status</span></td>
                                        <td class="text-muted small">@(p.User?.UserName ?? "â€”")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        </div>
    }

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         TAB: WORK ORDERS
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    @if (ActiveTab == "workorders")
    {
        <div class="rpt-section">
        <!-- KPI Row -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-purple">
                    <div class="rpt-kpi-icon"><i class="bi bi-list-task"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredOrders.Count</div>
                        <div class="rpt-kpi-label">Total Orders</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-green">
                    <div class="rpt-kpi-icon"><i class="bi bi-check2-all"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredOrders.Count(o => o.Status == "Completed")</div>
                        <div class="rpt-kpi-label">Completed</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-blue">
                    <div class="rpt-kpi-icon"><i class="bi bi-arrow-repeat"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredOrders.Count(o => o.Status == "In Progress")</div>
                        <div class="rpt-kpi-label">In Progress</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-amber">
                    <div class="rpt-kpi-icon"><i class="bi bi-hourglass-split"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredOrders.Count(o => o.Status == "Pending")</div>
                        <div class="rpt-kpi-label">Pending</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart.js: Order Status Breakdown -->
        <div class="rpt-chart-card mb-4">
            <div class="rpt-chart-header">
                <span class="rpt-chart-title"><i class="bi bi-pie-chart"></i> Order Status Breakdown</span>
            </div>
            <div class="rpt-chart-body">
                @if (!FilteredOrders.Any())
                {
                    <div class="rpt-empty"><i class="bi bi-pie-chart"></i>No work orders in selected range.</div>
                }
                else
                {
                    <div style="position:relative; height:300px; max-width:400px; margin:0 auto;">
                        <canvas id="orderStatusChart"></canvas>
                    </div>
                }
            </div>
        </div>

        <!-- Work Orders Table -->
        <div class="rpt-table-card">
            <div class="rpt-table-header">
                <span class="rpt-table-title"><i class="bi bi-table"></i> Work Order Details</span>
                <span class="badge bg-light text-dark border">@FilteredOrders.Count total</span>
            </div>
            <div style="padding: 0;">
                @if (!FilteredOrders.Any())
                {
                    <div class="rpt-empty"><i class="bi bi-inbox"></i>No records found.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">#</th>
                                    <th>Description</th>
                                    <th>Qty</th>
                                    <th>Start</th>
                                    <th>End</th>
                                    <th>Duration</th>
                                    <th>Status</th>
                                    <th>Assigned To</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var o in FilteredOrders)
                                {
                                    var duration = (o.StartTime.HasValue && o.EndTime.HasValue)
                                        ? (o.EndTime.Value - o.StartTime.Value).TotalHours.ToString("F1") + "h"
                                        : "â€”";
                                    <tr>
                                        <td class="text-muted small ps-3">@o.OrderID</td>
                                        <td class="fw-500">@o.OrderDescription</td>
                                        <td>@o.BatchQuantity.ToString("N0")</td>
                                        <td>@(o.StartTime?.ToString("MMM d, yyyy") ?? "â€”")</td>
                                        <td>@(o.EndTime?.ToString("MMM d, yyyy") ?? "â€”")</td>
                                        <td class="text-muted small">@duration</td>
                                        <td><span class="badge @GetOrderBadge(o.Status)">@o.Status</span></td>
                                        <td class="text-muted small">@(o.User?.UserName ?? "â€”")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        </div>
    }

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         TAB: INVENTORY
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    @if (ActiveTab == "inventory")
    {
        <div class="rpt-section">
        <!-- KPI Row -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-purple">
                    <div class="rpt-kpi-icon"><i class="bi bi-box-seam"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@AllComponents.Count(c => !c.IsArchived)</div>
                        <div class="rpt-kpi-label">Active Components</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-green">
                    <div class="rpt-kpi-icon"><i class="bi bi-arrow-down-circle"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredTransactions.Count(t => t.TransactionType == "Inbound")</div>
                        <div class="rpt-kpi-label">Inbound Txns</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-amber">
                    <div class="rpt-kpi-icon"><i class="bi bi-arrow-up-circle"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredTransactions.Count(t => t.TransactionType == "Outbound")</div>
                        <div class="rpt-kpi-label">Outbound Txns</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-red">
                    <div class="rpt-kpi-icon"><i class="bi bi-exclamation-triangle"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@LowStockCount</div>
                        <div class="rpt-kpi-label">Low Stock Alerts</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Component Stock Table -->
        <div class="rpt-table-card mb-4">
            <div class="rpt-table-header">
                <span class="rpt-table-title"><i class="bi bi-boxes"></i> Component Stock Levels</span>
                @if (LowStockCount > 0)
                {
                    <span class="badge bg-danger">@LowStockCount below minimum</span>
                }
            </div>
            <div style="padding: 0;">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-3">Component</th>
                                <th>Supplier</th>
                                <th>Unit Cost</th>
                                <th>Min Stock</th>
                                <th>Net Stock</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var comp in AllComponents.Where(c => !c.IsArchived).OrderBy(c => c.ComponentName))
                            {
                                var inbound = AllTransactions
                                    .Where(t => t.ComponentID == comp.ComponentID && t.TransactionType == "Inbound")
                                    .Sum(t => t.Quantity);
                                var outbound = AllTransactions
                                    .Where(t => t.ComponentID == comp.ComponentID && t.TransactionType == "Outbound")
                                    .Sum(t => t.Quantity);
                                var net = inbound - outbound;
                                var isLow = net < comp.MinStockLevel;
                                <tr class="@(isLow ? "table-danger-soft" : "")">
                                    <td class="fw-500 ps-3">@comp.ComponentName</td>
                                    <td class="text-muted small">@(comp.SupplierInfo ?? "â€”")</td>
                                    <td>@comp.CurrencyCode @comp.UnitCost.ToString("N2")</td>
                                    <td>@comp.MinStockLevel</td>
                                    <td class="fw-600 @(isLow ? "text-danger" : "text-success")">@net</td>
                                    <td>
                                        @if (isLow)
                                        {
                                            <span class="badge bg-danger">Low Stock</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">OK</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Transaction History -->
        <div class="rpt-table-card">
            <div class="rpt-table-header">
                <span class="rpt-table-title"><i class="bi bi-clock-history"></i> Transaction History</span>
                <span class="badge bg-light text-dark border">@FilteredTransactions.Count transactions</span>
            </div>
            <div style="padding: 0;">
                @if (!FilteredTransactions.Any())
                {
                    <div class="rpt-empty"><i class="bi bi-inbox"></i>No transactions in selected range.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Date</th>
                                    <th>Component</th>
                                    <th>Type</th>
                                    <th>Qty</th>
                                    <th>Work Order</th>
                                    <th>By</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in FilteredTransactions.OrderByDescending(x => x.TransactionDate))
                                {
                                    <tr>
                                        <td class="text-muted small ps-3">@t.TransactionDate.ToString("MMM d, yyyy")</td>
                                        <td class="fw-500">@(t.Component?.ComponentName ?? "â€”")</td>
                                        <td>
                                            <span class="badge @(t.TransactionType == "Inbound" ? "bg-success" : t.TransactionType == "Outbound" ? "bg-warning" : "bg-secondary")">
                                                @t.TransactionType
                                            </span>
                                        </td>
                                        <td class="fw-600">@t.Quantity</td>
                                        <td class="text-muted small">@(t.OrderID.HasValue ? $"#{t.OrderID}" : "â€”")</td>
                                        <td class="text-muted small">@(t.User?.UserName ?? "â€”")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        </div>
    }

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         TAB: COSTS
    â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
    @if (ActiveTab == "costs")
    {
        <div class="rpt-section">
        <!-- KPI Row -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-purple">
                    <div class="rpt-kpi-icon"><i class="bi bi-currency-dollar"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredCosts.Sum(c => c.Amount).ToString("N2")</div>
                        <div class="rpt-kpi-label">Total Cost</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-blue">
                    <div class="rpt-kpi-icon"><i class="bi bi-tools"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredCosts.Where(c => c.CostType == "Material").Sum(c => c.Amount).ToString("N2")</div>
                        <div class="rpt-kpi-label">Material Cost</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-green">
                    <div class="rpt-kpi-icon"><i class="bi bi-person-workspace"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredCosts.Where(c => c.CostType == "Labor").Sum(c => c.Amount).ToString("N2")</div>
                        <div class="rpt-kpi-label">Labor Cost</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="rpt-kpi rpt-kpi-amber">
                    <div class="rpt-kpi-icon"><i class="bi bi-building"></i></div>
                    <div class="rpt-kpi-body">
                        <div class="rpt-kpi-value">@FilteredCosts.Where(c => c.CostType == "Overhead").Sum(c => c.Amount).ToString("N2")</div>
                        <div class="rpt-kpi-label">Overhead Cost</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart.js: Cost Type Breakdown -->
        <div class="rpt-chart-card mb-4">
            <div class="rpt-chart-header">
                <span class="rpt-chart-title"><i class="bi bi-pie-chart"></i> Cost Type Breakdown</span>
            </div>
            <div class="rpt-chart-body">
                @if (!FilteredCosts.Any())
                {
                    <div class="rpt-empty"><i class="bi bi-pie-chart"></i>No cost records in selected range.</div>
                }
                else
                {
                    <div class="row g-4 align-items-center">
                        <div class="col-md-7">
                            <div style="position:relative; height:300px; max-width:400px; margin:0 auto;">
                                <canvas id="costTypeChart"></canvas>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="rpt-cost-summary">
                                @{
                                    var costGroups = FilteredCosts
                                        .GroupBy(c => c.CostType)
                                        .Select(g => new { Type = g.Key, Total = g.Sum(x => x.Amount) })
                                        .OrderByDescending(x => x.Total)
                                        .ToList();
                                    decimal totalCost = FilteredCosts.Sum(c => c.Amount);
                                    if (totalCost == 0) totalCost = 1;
                                }
                                @foreach (var cg in costGroups)
                                {
                                    var pct = (int)(cg.Total * 100 / totalCost);
                                    <div class="rpt-cost-row">
                                        <div class="rpt-cost-dot @GetCostDotClass(cg.Type)"></div>
                                        <span class="flex-grow-1">@cg.Type</span>
                                        <span class="fw-600">@pct%</span>
                                    </div>
                                }
                                <div class="rpt-cost-total mt-2 pt-2 border-top">
                                    <span class="fw-600">Total</span>
                                    <span class="fw-700 text-primary">â‚±@FilteredCosts.Sum(c => c.Amount).ToString("N2")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Cost Records Table -->
        <div class="rpt-table-card">
            <div class="rpt-table-header">
                <span class="rpt-table-title"><i class="bi bi-table"></i> Cost Records</span>
                <span class="badge bg-light text-dark border">@FilteredCosts.Count records</span>
            </div>
            <div style="padding: 0;">
                @if (!FilteredCosts.Any())
                {
                    <div class="rpt-empty"><i class="bi bi-inbox"></i>No cost records found.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Date</th>
                                    <th>Type</th>
                                    <th>Component</th>
                                    <th>Work Order</th>
                                    <th>Amount</th>
                                    <th>Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in FilteredCosts.OrderByDescending(x => x.RecordedDate))
                                {
                                    <tr>
                                        <td class="text-muted small ps-3">@c.RecordedDate.ToString("MMM d, yyyy")</td>
                                        <td><span class="badge @GetCostBadge(c.CostType)">@c.CostType</span></td>
                                        <td class="text-muted small">@(c.Component?.ComponentName ?? "â€”")</td>
                                        <td class="text-muted small">@(c.OrderID.HasValue ? $"#{c.OrderID}" : "â€”")</td>
                                        <td class="fw-600">@c.Amount.ToString("N2")</td>
                                        <td class="text-muted small">@c.CurrencyRate.ToString("F4")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        </div>
    }
}

@code {
    private bool IsLoading = true;
    private string ActiveTab = "production";

    // Date filters
    private DateTime FilterFrom = DateTime.Today.AddMonths(-3);
    private DateTime FilterTo   = DateTime.Today;

    // Facility access
    private int? userFacilityId;
    private bool isSuperAdmin;

    [Inject] private production_system.Services.FacilityAccessService FacilityAccess { get; set; } = default!;

    // Raw data
    private List<ProductionPlan>       AllPlans        = new();
    private List<WorkOrder>            AllOrders       = new();
    private List<Component>            AllComponents   = new();
    private List<InventoryTransaction> AllTransactions = new();
    private List<Cost>                 AllCosts        = new();

    // Filtered views
    private List<ProductionPlan>       FilteredPlans        => AllPlans.Where(p => p.PlannedStartDate >= FilterFrom && p.PlannedStartDate <= FilterTo).ToList();
    private List<WorkOrder>            FilteredOrders       => AllOrders.Where(o => (!o.StartTime.HasValue || o.StartTime.Value >= FilterFrom) && (!o.StartTime.HasValue || o.StartTime.Value <= FilterTo)).ToList();
    private List<InventoryTransaction> FilteredTransactions => AllTransactions.Where(t => t.TransactionDate >= FilterFrom && t.TransactionDate <= FilterTo).ToList();
    private List<Cost>                 FilteredCosts        => AllCosts.Where(c => c.RecordedDate >= FilterFrom && c.RecordedDate <= FilterTo).ToList();

    private int LowStockCount => AllComponents.Where(c => !c.IsArchived).Count(comp =>
    {
        var inbound  = AllTransactions.Where(t => t.ComponentID == comp.ComponentID && t.TransactionType == "Inbound").Sum(t => t.Quantity);
        var outbound = AllTransactions.Where(t => t.ComponentID == comp.ComponentID && t.TransactionType == "Outbound").Sum(t => t.Quantity);
        return (inbound - outbound) < comp.MinStockLevel;
    });

    protected override async Task OnInitializedAsync()
    {
        isSuperAdmin = await FacilityAccess.IsSuperAdminAsync();
        userFacilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();
        await LoadData();
        IsLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsLoading)
        {
            await RenderCharts();
        }
    }

    private async Task RenderCharts()
    {
        try
        {
            if (ActiveTab == "production" && FilteredPlans.Any())
            {
                var byProduct = FilteredPlans
                    .GroupBy(p => p.Product?.ProductName ?? "Unknown")
                    .Select(g => new { Product = g.Key, Units = g.Sum(x => x.BatchQuantity) })
                    .OrderByDescending(x => x.Units)
                    .ToList();
                var labels = byProduct.Select(x => x.Product).ToArray();
                var data = byProduct.Select(x => (object)x.Units).ToArray();
                await JS.InvokeVoidAsync("chartInterop.createBarChart", "productionBarChart", labels, data, "Units Planned");
            }

            if (ActiveTab == "workorders" && FilteredOrders.Any())
            {
                var statusGroups = FilteredOrders
                    .GroupBy(o => o.Status)
                    .Select(g => new { Status = g.Key, Count = g.Count() })
                    .ToList();
                var labels = statusGroups.Select(x => x.Status).ToArray();
                var data = statusGroups.Select(x => (object)x.Count).ToArray();
                await JS.InvokeVoidAsync("chartInterop.createDoughnutChart", "orderStatusChart", labels, data);
            }

            if (ActiveTab == "costs" && FilteredCosts.Any())
            {
                var costGroups = FilteredCosts
                    .GroupBy(c => c.CostType)
                    .Select(g => new { Type = g.Key, Total = g.Sum(x => x.Amount) })
                    .ToList();
                var labels = costGroups.Select(x => x.Type).ToArray();
                var data = costGroups.Select(x => (object)x.Total).ToArray();
                await JS.InvokeVoidAsync("chartInterop.createDoughnutChart", "costTypeChart", labels, data);
            }
        }
        catch
        {
            // Chart rendering may fail during SSR or prerender
        }
    }

    private async Task LoadData()
    {
        using var scope = ScopeFactory.CreateScope();
        var context = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        var planQuery = context.ProductionPlans
            .Include(p => p.Product)
            .Include(p => p.User)
            .AsQueryable();
        if (!isSuperAdmin && userFacilityId.HasValue)
            planQuery = planQuery.Where(p => p.FacilityID == userFacilityId.Value);
        AllPlans = await planQuery.ToListAsync();

        var orderQuery = context.WorkOrders
            .Include(o => o.User)
            .AsQueryable();
        if (!isSuperAdmin && userFacilityId.HasValue)
            orderQuery = orderQuery.Where(o => o.FacilityID == userFacilityId.Value);
        AllOrders = await orderQuery.ToListAsync();

        var componentQuery = context.Components.AsQueryable();
        if (!isSuperAdmin && userFacilityId.HasValue)
            componentQuery = componentQuery.Where(c => c.FacilityID == userFacilityId.Value);
        AllComponents = await componentQuery.ToListAsync();

        var txnQuery = context.InventoryTransactions
            .Include(t => t.Component)
            .Include(t => t.User)
            .AsQueryable();
        if (!isSuperAdmin && userFacilityId.HasValue)
            txnQuery = txnQuery.Where(t => t.FacilityID == userFacilityId.Value);
        AllTransactions = await txnQuery.ToListAsync();

        var costQuery = context.Costs
            .Include(c => c.Component)
            .AsQueryable();
        if (!isSuperAdmin && userFacilityId.HasValue)
            costQuery = costQuery.Where(c => c.FacilityID == userFacilityId.Value);
        AllCosts = await costQuery.ToListAsync();
    }

    private Task ApplyFilters()
    {
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task PrintReport()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    // Badge helpers
    private string GetPlanBadge(string s) => s switch
    {
        "Completed" => "bg-success",
        "Active"    => "bg-primary",
        "Draft"     => "bg-secondary",
        "Archived"  => "bg-warning",
        "Canceled"  => "bg-danger",
        _           => "bg-primary"
    };

    private string GetOrderBadge(string s) => s switch
    {
        "Completed"   => "bg-success",
        "In Progress" => "bg-info",
        "Pending"     => "bg-warning",
        _             => "bg-secondary"
    };

    private string GetOrderBarClass(string s) => s switch
    {
        "Completed"   => "rpt-bar-green",
        "In Progress" => "rpt-bar-blue",
        "Pending"     => "rpt-bar-amber",
        _             => "rpt-bar-purple"
    };

    private string GetCostBadge(string s) => s switch
    {
        "Material" => "bg-info",
        "Labor"    => "bg-success",
        "Overhead" => "bg-warning",
        _          => "bg-secondary"
    };

    private string GetCostBarClass(string s) => s switch
    {
        "Material" => "rpt-bar-blue",
        "Labor"    => "rpt-bar-green",
        "Overhead" => "rpt-bar-amber",
        _          => "rpt-bar-purple"
    };

    private string GetCostDotClass(string s) => s switch
    {
        "Material" => "dot-blue",
        "Labor"    => "dot-green",
        "Overhead" => "dot-amber",
        _          => "dot-purple"
    };
}

