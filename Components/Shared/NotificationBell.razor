@using production_system.Services
@using production_system.Models
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject production_system.Services.FacilityAccessService FacilityAccess
@rendermode InteractiveServer

<div class="notif-wrapper">
    <button class="notif-bell" @onclick="TogglePanelAndRefresh" title="Notifications">
        <i class="bi @(isRefreshing ? "bi-arrow-clockwise spin" : "bi-bell")"></i>
        @if (unreadCount > 0)
        {
            <span class="notif-dot"></span>
        }
    </button>

    @if (isOpen)
    {
        <div class="notif-backdrop" @onclick="ClosePanel"></div>
        <div class="notif-panel">
            <div class="notif-panel-header">
                <span class="notif-panel-title">Notifications</span>
                <div class="d-flex align-items-center gap-2">
                    @if (unreadCount > 0)
                    {
                        <button class="notif-mark-all" @onclick="MarkAllRead" title="Mark all as read">
                            <i class="bi bi-check-all"></i>
                        </button>
                    }
                </div>
            </div>

            <div class="notif-panel-body">
                @if (notifications == null || isRefreshing)
                {
                    <div class="notif-empty">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <span class="ms-2 text-muted">Loading...</span>
                    </div>
                }
                else if (!notifications.Any())
                {
                    <div class="notif-empty">
                        <i class="bi bi-bell-slash"></i>
                        <span>No notifications</span>
                        <small class="text-muted">You're all caught up!</small>
                    </div>
                }
                else
                {
                    @foreach (var n in notifications)
                    {
                        <div class="notif-item @(n.IsRead ? "" : "unread") @GetSeverityClass(n.Severity)" @onclick="() => HandleClick(n)">
                            <div class="notif-item-icon">
                                <i class="bi @GetCategoryIcon(n.Category)"></i>
                            </div>
                            <div class="notif-item-content">
                                <div class="notif-item-title">@n.Title</div>
                                <div class="notif-item-msg">@n.Message</div>
                                <div class="notif-item-time">
                                    <i class="bi bi-clock me-1"></i>@FormatTime(n.CreatedAt)
                                </div>
                            </div>
                            <button class="notif-item-dismiss" @onclick:stopPropagation="true" @onclick="() => Dismiss(n)" title="Dismiss">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    }
                }
            </div>
        </div>
    }
</div>

<style>
    .notif-wrapper {
        position: relative;
    }

    .notif-bell {
        background: none;
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ns-text-secondary);
        cursor: pointer;
        transition: all 0.15s ease;
        position: relative;
        font-size: 1.25rem;
    }

    .notif-bell:hover {
        background: rgba(143, 0, 255, 0.08);
        color: var(--ns-primary);
    }

    .notif-dot {
        position: absolute;
        top: 11px;
        right: 12px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #D10000;
        border: 2px solid var(--ns-card-bg, #fff);
        animation: notifPulse 2s ease-in-out infinite;
    }

    @@keyframes notifPulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    .notif-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1098;
    }

    .notif-panel {
        position: absolute;
        top: 100%;
        right: 0;
        width: 360px;
        max-height: 480px;
        background: var(--ns-card-bg, white);
        border: 1px solid var(--ns-border, #e5e7eb);
        border-radius: 0.75rem;
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12), 0 4px 12px rgba(0, 0, 0, 0.06);
        z-index: 1099;
        display: flex;
        flex-direction: column;
        animation: notifSlideIn 0.15s ease-out;
        overflow: hidden;
    }

    @@keyframes notifSlideIn {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .notif-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid var(--ns-border, #e5e7eb);
        background: #fafbfc;
    }

    .notif-panel-title {
        font-weight: 700;
        font-size: 0.875rem;
        color: var(--ns-text-dark, #1e1b4b);
    }

    .notif-mark-all, .notif-refresh {
        background: none;
        border: none;
        color: var(--ns-primary, #8F00FF);
        cursor: pointer;
        padding: 0.25rem;
        border-radius: 0.25rem;
        font-size: 1rem;
        transition: background 0.12s ease;
    }

    .notif-mark-all:hover, .notif-refresh:hover {
        background: rgba(143, 0, 255, 0.08);
    }

    .notif-panel-body {
        overflow-y: auto;
        flex: 1;
        max-height: 400px;
    }

    .notif-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2.5rem 1rem;
        color: #9ca3af;
        gap: 0.5rem;
    }

    .notif-empty .bi {
        font-size: 2rem;
        opacity: 0.4;
    }

    .notif-item {
        display: flex;
        align-items: flex-start;
        gap: 0.625rem;
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #f3f4f6;
        cursor: pointer;
        transition: background 0.12s ease;
        position: relative;
    }

    .notif-item:hover {
        background: #f9fafb;
    }

    .notif-item.unread {
        background: rgba(143, 0, 255, 0.03);
    }

    .notif-item.unread::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: var(--ns-primary, #8F00FF);
        border-radius: 0 2px 2px 0;
    }

    .notif-item.severity-warning .notif-item-icon {
        color: #FF964F;
        background: rgba(255, 150, 79, 0.1);
    }

    .notif-item.severity-critical .notif-item-icon {
        color: #D10000;
        background: rgba(209, 0, 0, 0.1);
    }

    .notif-item-icon {
        width: 32px;
        height: 32px;
        border-radius: 0.375rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ns-primary, #8F00FF);
        background: rgba(143, 0, 255, 0.08);
        flex-shrink: 0;
        font-size: 0.875rem;
    }

    .notif-item-content {
        flex: 1;
        min-width: 0;
    }

    .notif-item-title {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--ns-text-dark, #1e1b4b);
        line-height: 1.3;
    }

    .notif-item-msg {
        font-size: 0.75rem;
        color: #6b7280;
        margin-top: 0.125rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .notif-item-time {
        font-size: 0.625rem;
        color: #9ca3af;
        margin-top: 0.25rem;
    }

    .notif-item-dismiss {
        background: none;
        border: none;
        color: #9ca3af;
        cursor: pointer;
        padding: 0.125rem;
        border-radius: 0.25rem;
        font-size: 0.875rem;
        opacity: 0;
        transition: opacity 0.12s ease, color 0.12s ease;
        flex-shrink: 0;
    }

    .notif-item:hover .notif-item-dismiss {
        opacity: 1;
    }

    .notif-item-dismiss:hover {
        color: #D10000;
    }

    .spin {
        animation: spinAnim 0.6s linear infinite;
    }

    @@keyframes spinAnim {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    /* Mobile responsive */
    @@media (max-width: 576px) {
        .notif-panel {
            width: calc(100vw - 1rem);
            right: -0.5rem;
            max-height: 70vh;
        }
    }
</style>

@code {
    private bool isOpen = false;
    private bool isRefreshing = false;
    private int unreadCount = 0;
    private List<SystemNotification>? notifications;
    private string? userId;
    private int? facilityId;
    private List<string> userRoles = new();
    private System.Threading.Timer? refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadUserContext();
        await RefreshNotifications();

        // Auto-refresh every 60 seconds
        refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await RefreshNotifications();
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
    }

    private async Task LoadUserContext()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            userRoles = user.Claims
                .Where(c => c.Type == ClaimTypes.Role)
                .Select(c => c.Value)
                .ToList();
            facilityId = await FacilityAccess.GetCurrentUserFacilityIdAsync();
        }
    }

    private async Task RefreshNotifications()
    {
        if (string.IsNullOrEmpty(userId)) return;

        isRefreshing = true;

        try
        {
            // Generate fresh alerts from system data
            await NotificationService.GenerateSystemAlertsAsync();
        }
        catch
        {
            // Alert generation is best-effort; don't break the UI
        }

        try
        {
            notifications = await NotificationService.GetNotificationsAsync(userId, facilityId, userRoles);
            unreadCount = notifications.Count(n => !n.IsRead);
        }
        catch
        {
            notifications = new();
            unreadCount = 0;
        }

        isRefreshing = false;
    }

    private async Task TogglePanelAndRefresh()
    {
        isOpen = !isOpen;
        if (isOpen)
        {
            await RefreshNotifications();
        }
    }

    private void ClosePanel()
    {
        isOpen = false;
    }

    private async Task HandleClick(SystemNotification n)
    {
        if (!n.IsRead)
        {
            await NotificationService.MarkAsReadAsync(n.NotificationID);
            n.IsRead = true;
            unreadCount = Math.Max(0, unreadCount - 1);
        }
    }

    private async Task Dismiss(SystemNotification n)
    {
        await NotificationService.DismissAsync(n.NotificationID);
        notifications?.Remove(n);
        if (!n.IsRead) unreadCount = Math.Max(0, unreadCount - 1);
    }

    private async Task MarkAllRead()
    {
        if (string.IsNullOrEmpty(userId)) return;
        await NotificationService.MarkAllAsReadAsync(userId, facilityId, userRoles);
        if (notifications != null)
        {
            foreach (var n in notifications)
                n.IsRead = true;
        }
        unreadCount = 0;
    }

    private string GetCategoryIcon(string category) => category switch
    {
        "LowStock" => "bi-box-seam",
        "EnvironmentAlert" => "bi-thermometer-high",
        "WorkOrder" => "bi-clipboard-check",
        "Production" => "bi-gear-wide-connected",
        _ => "bi-info-circle"
    };

    private string GetSeverityClass(string severity) => severity switch
    {
        "Critical" => "severity-critical",
        "Warning" => "severity-warning",
        _ => ""
    };

    private string FormatTime(DateTime utcTime)
    {
        var local = utcTime.ToLocalTime();
        var diff = DateTime.Now - local;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return local.ToString("MMM dd");
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
    }
}

