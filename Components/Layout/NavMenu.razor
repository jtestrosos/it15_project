                </div>

                <!-- Administration -->
                <div class="nav-item px-3 mt-2">
                    <small class="text-muted px-2" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;">Administration</small>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/users">
                        <span class="bi bi-shield-lock" aria-hidden="true"></span> User Management
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/logs">
                        <span class="bi bi-journal-text" aria-hidden="true"></span> Audit Logs
                    </NavLink>
                </div>

                <!-- System Core -->
                <div class="nav-item px-3 mt-2">
                    <small class="text-muted px-2" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;">System Core</small>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/facilities">
