@page "/login"
@layout AccountLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using production_system.Data
@using production_system.Components.Account.Shared
@using production_system.Services

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject IRecaptchaService RecaptchaService
@inject IConfiguration Configuration
@inject AuditLogService AuditLog

<PageTitle>NodeSync | Login</PageTitle>

<div class="login-content">
    <div class="login-header">
        <h1>Welcome Back</h1>
        <p>Sign in to access the production system</p>
    </div>

    <StatusMessage Message="@errorMessage" />
    
    <EditForm EditContext="editContext" method="post" OnSubmit="LoginUser" FormName="login" id="login-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-errors" role="alert" />
        
        <div class="form-group">
            <label for="Input.Email">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4Zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2Zm13 2.383-4.708 2.825L15 11.105V5.383Zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741ZM1 11.105l4.708-2.897L1 5.383v5.722Z"/>
                </svg>
                Email Address
            </label>
            <InputText @bind-Value="Input.Email" id="Input.Email" class="form-input" autocomplete="username webauthn" aria-required="true" placeholder="Enter your email" 
                       onfocus="if(window.innerWidth < 768) { setTimeout(() => document.getElementById('login-submit-btn')?.scrollIntoView({behavior:'smooth', block:'end'}), 300); }" />
            <ValidationMessage For="() => Input.Email" class="field-error" />
        </div>
        
        <div class="form-group">
            <label for="Input.Password">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                </svg>
                Password
            </label>
            <InputText type="password" @bind-Value="Input.Password" id="Input.Password" class="form-input" autocomplete="current-password" aria-required="true" placeholder="Enter your password" 
                       onfocus="if(window.innerWidth < 768) { setTimeout(() => document.getElementById('login-submit-btn')?.scrollIntoView({behavior:'smooth', block:'end'}), 300); }" />
            <ValidationMessage For="() => Input.Password" class="field-error" />
        </div>
        
        <div class="form-options">
            <label class="remember-me">
                <InputCheckbox @bind-Value="Input.RememberMe" class="checkbox-input" />
                <span class="checkbox-custom"></span>
                Remember me
            </label>
            <a href="Account/ForgotPassword" class="forgot-link">Forgot password?</a>
        </div>

        @if (showRecaptcha)
        {
            <input type="hidden" name="Input.RecaptchaToken" id="recaptcha-token" />
        }
        
        <button type="submit" class="btn-login" id="login-submit-btn">
            <span>Sign In</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z"/>
            </svg>
        </button>
        
        <div class="divider">
            <span>or continue with</span>
        </div>
        
        <PasskeySubmit Operation="PasskeyOperation.Request" Name="Input.Passkey" EmailName="Input.Email" class="btn-passkey">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path d="M12.5 9a3.5 3.5 0 1 1 0 7 3.5 3.5 0 0 1 0-7Zm.354 5.854 1.5-1.5a.5.5 0 0 0-.707-.708l-.647.647V10.5a.5.5 0 0 0-1 0v2.793l-.647-.647a.5.5 0 0 0-.708.708l1.5 1.5a.5.5 0 0 0 .708 0ZM3.5 5a2.5 2.5 0 1 1 5 0 2.5 2.5 0 0 1-5 0ZM6 6.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/>
                <path d="M1.5 14A2.5 2.5 0 0 1 4 11.5h3.5A1.5 1.5 0 0 1 9 13v.5a.5.5 0 0 1-1 0V13a.5.5 0 0 0-.5-.5H4A1.5 1.5 0 0 0 2.5 14v.5a.5.5 0 0 1-1 0V14Z"/>
            </svg>
            <span>Sign in with Passkey</span>
        </PasskeySubmit>
    </EditForm>
</div>

@* Load reCAPTCHA v3 script only when verification is needed *@
@if (showRecaptcha)
{
    <script src="https://www.google.com/recaptcha/api.js?render=@recaptchaSiteKey" async defer></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var form = document.getElementById('login-form');
            if (form) {
                form.addEventListener('submit', function(e) {
                    var tokenInput = document.getElementById('recaptcha-token');
                    // If we haven't generated a token yet, stop submit and get one
                    if (tokenInput && !tokenInput.value) {
                        e.preventDefault();
                        grecaptcha.ready(function() {
                            grecaptcha.execute('@recaptchaSiteKey', {action: 'login'}).then(function(token) {
                                tokenInput.value = token;
                                form.submit(); // Now submit the form natively
                            });
                        });
                    }
                });
            }
        });
    </script>
}

<style>
    .grecaptcha-badge { 
        visibility: hidden; 
</style>

@code {
    private string? errorMessage;
    private EditContext editContext = default!;
    private string recaptchaSiteKey = "";
    private bool showRecaptcha = false;
    
    // In-memory tracker for non-existent emails to prevent brute-force enumeration
    private static readonly Dictionary<string, (int FailedCount, DateTimeOffset? LockoutEnd)> UnknownUserTracking = new();

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();
        editContext = new EditContext(Input);
        recaptchaSiteKey = Configuration["Recaptcha:SiteKey"] ?? "";

        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
        else if (HttpMethods.IsPost(HttpContext.Request.Method) && !string.IsNullOrEmpty(Input.Email))
        {
            // On POST, check the user's failed attempt count to decide if reCAPTCHA should appear
            var user = await UserManager.FindByEmailAsync(Input.Email);
            if (user != null)
            {
                var failedCount = await UserManager.GetAccessFailedCountAsync(user);
                var role = await GetPrimaryRoleAsync(user);
                int captchaThreshold = GetCaptchaThreshold(role);
                showRecaptcha = failedCount >= captchaThreshold;
            }
            else
            {
                // Check unknown user tracking
                if (UnknownUserTracking.TryGetValue(Input.Email, out var track))
                {
                    showRecaptcha = track.FailedCount >= 2;
                }
            }
        }
    }

    public async Task LoginUser()
    {
        if (!string.IsNullOrEmpty(Input.Passkey?.Error))
        {
            errorMessage = $"Error: {Input.Passkey.Error}";
            return;
        }

        // Check early lockout for unknown users
        if (UnknownUserTracking.TryGetValue(Input.Email, out var tracking))
        {
            if (tracking.LockoutEnd.HasValue && tracking.LockoutEnd.Value > DateTimeOffset.UtcNow)
            {
                await AuditLog.LogSecurityEventAsync("", "Account Locked", $"Lockout enforced for non-existent email '{Input.Email}'", production_system.Models.LogSeverity.Critical);
                Logger.LogWarning("Unknown user email locked out.");
                RedirectManager.RedirectTo("Account/Lockout");
                return;
            }
        }

        SignInResult result;
        if (!string.IsNullOrEmpty(Input.Passkey?.CredentialJson))
        {
            result = await SignInManager.PasskeySignInAsync(Input.Passkey.CredentialJson);
            
            if (result.Succeeded)
            {
                var user = await UserManager.FindByEmailAsync(Input.Email);
                if (user != null && user.IsArchived)
                {
                    await SignInManager.SignOutAsync();
                    await AuditLog.LogSecurityEventAsync(user.Id, "Login Blocked", $"Archived user '{Input.Email}' attempted passkey login", production_system.Models.LogSeverity.Warning, "User", user.Id);
                    errorMessage = "Error: Your account has been archived. Please contact an administrator.";
                    return;
                }
            }
        }
        else
        {
            if (!editContext.Validate())
            {
                return;
            }

            // If reCAPTCHA is required, validate it via v3 token
            if (showRecaptcha)
            {
                var recaptchaToken = Input.RecaptchaToken;
                if (string.IsNullOrEmpty(recaptchaToken))
                {
                    await AuditLog.LogSecurityEventAsync("", "reCAPTCHA Missing", $"Login attempt without reCAPTCHA for '{Input.Email}'", production_system.Models.LogSeverity.Warning);
                    errorMessage = "Error: Please wait for security verification to complete.";
                    return;
                }

                var isRecaptchaValid = await RecaptchaService.VerifyTokenAsync(recaptchaToken);
                if (!isRecaptchaValid)
                {
                    await AuditLog.LogSecurityEventAsync("", "reCAPTCHA Failed", $"reCAPTCHA v3 verification failed for '{Input.Email}' - possible bot attack", production_system.Models.LogSeverity.Critical);
                    errorMessage = "Error: Security verification failed (Bot detected). Please try again later.";
                    return;
                }
            }

            // Check for archived user
            var user = await UserManager.FindByEmailAsync(Input.Email);
            if (user != null && user.IsArchived)
            {
                await AuditLog.LogSecurityEventAsync(user.Id, "Login Blocked", $"Archived user '{Input.Email}' attempted login", production_system.Models.LogSeverity.Warning, "User", user.Id);
                errorMessage = "Error: Invalid email or password.";
                return;
            }

            result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: true);
        }

        if (result.Succeeded)
        {
            var loggedInUser = await UserManager.FindByEmailAsync(Input.Email);
            await AuditLog.LogSecurityEventAsync(loggedInUser?.Id ?? "", "Login Success", $"User '{Input.Email}' logged in successfully", production_system.Models.LogSeverity.Info, "User", loggedInUser?.Id);
            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(ReturnUrl ?? "/");
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            var lockedUser = await UserManager.FindByEmailAsync(Input.Email);
            if (lockedUser != null)
            {
                var role = await GetPrimaryRoleAsync(lockedUser);
                // Admins get a longer lockout (30 min instead of 15)
                if (role == "Administrator")
                {
                    await UserManager.SetLockoutEndDateAsync(lockedUser, DateTimeOffset.UtcNow.AddMinutes(30));
                }
                
                await AuditLog.LogSecurityEventAsync(lockedUser.Id, "Account Locked", $"Account locked for '{Input.Email}' (role: {role})", production_system.Models.LogSeverity.Critical, "User", lockedUser.Id);
                
                // Automated SIEM Notification (Simulated Email)
                Logger.LogWarning($"[EMAIL DISPATCH] To: {lockedUser.Email} | Subject: Security Alert: Account Locked | Body: Your account has been locked due to multiple failed login attempts.");
            }
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            // Login failed — check if we need role-specific early lockout
            var failedUser = await UserManager.FindByEmailAsync(Input.Email);
            if (failedUser != null)
            {
                var role = await GetPrimaryRoleAsync(failedUser);
                var failedCount = await UserManager.GetAccessFailedCountAsync(failedUser);

                // Superadmin: lock at 3 attempts (stricter than the global 5) and make it INDEFINITE
                if (role == "Superadmin" && failedCount >= 3)
                {
                    // Indefinite Lockout: completely freeze the account until manual unlock
                    await UserManager.SetLockoutEndDateAsync(failedUser, DateTimeOffset.MaxValue);
                    
                    await AuditLog.LogSecurityEventAsync(failedUser.Id, "Account Locked", $"Superadmin '{Input.Email}' locked indefinitely after {failedCount} failed attempts. Manual unlock required.", production_system.Models.LogSeverity.Critical, "User", failedUser.Id);
                    
                    // Automated SIEM Notification (Simulated Email)
                    Logger.LogWarning($"[EMAIL DISPATCH] To: {failedUser.Email} | Subject: CRITICAL: Superadmin Account Locked | Body: Your Superadmin account has been locked indefinitely due to multiple failed login attempts. A manual unlock by another Superadmin is required.");
                    
                    RedirectManager.RedirectTo("Account/Lockout");
                    return;
                }

                // Log warning when reCAPTCHA threshold is hit
                int captchaThreshold = GetCaptchaThreshold(role);
                if (failedCount == captchaThreshold)
                {
                    await AuditLog.LogSecurityEventAsync(failedUser.Id, "reCAPTCHA Triggered", $"reCAPTCHA activated for '{Input.Email}' (role: {role}) after {failedCount} failed attempts", production_system.Models.LogSeverity.Warning, "User", failedUser.Id);
                }

                await AuditLog.LogSecurityEventAsync(failedUser.Id, "Login Failed", $"Failed login attempt #{failedCount} for '{Input.Email}' (role: {role})", production_system.Models.LogSeverity.Warning, "User", failedUser.Id);

                showRecaptcha = failedCount >= captchaThreshold;
            }
            else
            {
                // Treat non-existent users exactly like Workers (2 fails = reCAPTCHA, 5 fails = Lockout)
                var track = UnknownUserTracking.GetValueOrDefault(Input.Email, (0, null));
                track.FailedCount++;
                
                if (track.FailedCount >= 5)
                {
                    track.LockoutEnd = DateTimeOffset.UtcNow.AddMinutes(15);
                    UnknownUserTracking[Input.Email] = track;
                    
                    await AuditLog.LogSecurityEventAsync("", "Account Locked", $"Unknown email '{Input.Email}' locked out after {track.FailedCount} failed attempts", production_system.Models.LogSeverity.Critical);
                    RedirectManager.RedirectTo("Account/Lockout");
                    return;
                }
                else
                {
                    UnknownUserTracking[Input.Email] = track;
                    
                    if (track.FailedCount == 2)
                    {
                        await AuditLog.LogSecurityEventAsync("", "reCAPTCHA Triggered", $"reCAPTCHA activated for unknown email '{Input.Email}' after {track.FailedCount} failed attempts", production_system.Models.LogSeverity.Warning);
                    }
                    
                    await AuditLog.LogSecurityEventAsync("", "Login Failed", $"Failed login attempt #{track.FailedCount} for unknown email '{Input.Email}'", production_system.Models.LogSeverity.Warning);
                    showRecaptcha = track.FailedCount >= 2;
                }
            }
            // Never reveal which field (email vs password) was wrong
            errorMessage = "Error: Invalid email or password.";
        }
    }

    /// <summary>
    /// Returns the reCAPTCHA threshold per role:
    /// Superadmin = 1 (show after 1 failure), others = 2 (show after 2 failures)
    /// </summary>
    private int GetCaptchaThreshold(string? role) => role switch
    {
        "Superadmin" => 1,
        _ => 2
    };

    /// <summary>
    /// Get the user's primary (highest) role.
    /// </summary>
    private async Task<string?> GetPrimaryRoleAsync(ApplicationUser user)
    {
        var roles = await UserManager.GetRolesAsync(user);
        // Return highest privilege role
        if (roles.Contains("Superadmin")) return "Superadmin";
        if (roles.Contains("Administrator")) return "Administrator";
        if (roles.Contains("ProductionManager")) return "ProductionManager";
        if (roles.Contains("ProductionWorker")) return "ProductionWorker";
        return roles.FirstOrDefault();
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }

        public string? RecaptchaToken { get; set; }

        public PasskeyInputModel? Passkey { get; set; }
    }
}
