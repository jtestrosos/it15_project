@page "/Account/Lockout"
@layout AccountLayout

@using production_system.Components.Account.Shared

<PageTitle>NodeSync | Account Locked</PageTitle>

<div class="login-content">
    <div class="lockout-icon-wrapper">
        <div class="lockout-icon-ring">
            <div class="lockout-icon-inner">
                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                </svg>
            </div>
        </div>
    </div>

    <div class="login-header" style="margin-bottom: 1.25rem;">
        <h1 style="font-size: 1.4rem; margin-bottom: 0.5rem;">Account Locked</h1>
        <p style="font-size: 0.85rem; line-height: 1.5;">
            Too many failed login attempts detected.<br />
            Your account has been temporarily locked for security.
        </p>
    </div>

    <div class="lockout-info-card">
        <div class="lockout-info-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71V3.5z"/>
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0z"/>
            </svg>
            <div>
                <span class="lockout-info-label">Lockout Duration</span>
                <span class="lockout-info-value">15 minutes</span>
            </div>
        </div>
        <div class="lockout-info-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
            </svg>
            <div>
                <span class="lockout-info-label">What to do</span>
                <span class="lockout-info-value">Wait and try again, or contact an admin</span>
            </div>
        </div>
    </div>

    <a href="/login" class="btn-login" style="text-decoration: none; margin-top: 0.5rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5z"/>
        </svg>
        <span>Back to Login</span>
    </a>

    <div class="login-footer">
        <p style="font-size: 0.75rem; color: #9ca3af; margin: 0;">
            This security measure protects your account from unauthorized access.
        </p>
    </div>
</div>

<style>
    .lockout-icon-wrapper {
        display: flex;
        justify-content: center;
        margin-bottom: 1.25rem;
    }

    .lockout-icon-ring {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(220, 38, 38, 0.1) 0%, rgba(220, 38, 38, 0.05) 100%);
        border: 2px solid rgba(220, 38, 38, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        animation: lockPulse 2s ease-in-out infinite;
    }

    .lockout-icon-inner {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        box-shadow: 0 4px 15px rgba(220, 38, 38, 0.35);
    }

    @@keyframes lockPulse {
        0%, 100% { transform: scale(1); border-color: rgba(220, 38, 38, 0.15); }
        50% { transform: scale(1.04); border-color: rgba(220, 38, 38, 0.3); }
    }

    .lockout-info-card {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.85rem;
    }

    .lockout-info-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        color: #991b1b;
    }

    .lockout-info-row svg {
        flex-shrink: 0;
        margin-top: 2px;
        opacity: 0.7;
    }

    .lockout-info-row > div {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
    }

    .lockout-info-label {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #b91c1c;
    }

    .lockout-info-value {
        font-size: 0.85rem;
        color: #7f1d1d;
        font-weight: 500;
    }
</style>
