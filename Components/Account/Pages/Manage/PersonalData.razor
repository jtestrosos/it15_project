@page "/Account/Manage/PersonalData"

@using Microsoft.AspNetCore.Identity
@using production_system.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>NodeSync | Account Settings</PageTitle>

<StatusMessage />

<div class="card mb-4">
    <div class="card-header">
        <i class="bi bi-database me-1"></i> Personal Data
    </div>
    <div class="card-body p-4 text-center">
        <div class="personal-data-icon-lg mb-3 mx-auto">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h5 class="fw-bold mb-2">Manage Your Data</h5>
        <p class="text-muted small mb-4 mx-auto" style="max-width: 600px;">
            Your account contains personal data that you have provided. This page allows you to download a copy of your data.
        </p>

        <div class="d-flex flex-column gap-3 align-items-center">
            <!-- Download Data -->
            <div class="personal-data-action w-100" style="max-width: 600px;">
                <div class="personal-data-action-icon bg-primary-subtle">
                    <i class="bi bi-cloud-arrow-down text-primary"></i>
                </div>
                <div class="flex-grow-1 text-start">
                    <strong class="d-block mb-1">Download Your Data</strong>
                    <span class="text-muted small">Get a copy of all personal data stored in your account.</span>
                </div>
                <form action="Account/Manage/DownloadPersonalData" method="post" class="ms-3">
                    <AntiforgeryToken />
                    <button class="btn btn-primary px-3" type="submit">
                        <i class="bi bi-download me-1"></i> Download
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .personal-data-icon-lg {
        width: 64px;
        height: 64px;
        border-radius: 12px;
        background: rgba(143, 0, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: var(--ns-primary);
    }

    .personal-data-action {
        display: flex;
        align-items: center;
        gap: 0.875rem;
        padding: 1rem;
        border: 1px solid var(--ns-border);
        border-radius: 0.5rem;
        transition: border-color 0.15s ease;
    }

    .personal-data-action:hover {
        border-color: #d0d7de;
    }

    .personal-data-action-icon {
        width: 40px;
        height: 40px;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.125rem;
        flex-shrink: 0;
    }

    .bg-primary-subtle {
        background: rgba(143, 0, 255, 0.1);
    }

    .bg-danger-subtle {
        background: rgba(239, 68, 68, 0.1);
    }
</style>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user  = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }
    }
}

