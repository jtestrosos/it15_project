@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="auth-page">
    <div class="auth-background" style="background-color: #e5e7eb;">
        <canvas id="interactive-bg"></canvas>
    </div>
    
    <div class="auth-container">
        <div class="auth-brand">
            <div class="brand-icon">
                <img src="favicon.png" width="48" height="48" alt="NodeSync Logo" />
            </div>
            <h1 class="brand-title">NodeSync</h1>
            <p class="brand-subtitle">Integrated Production System</p>
        </div>
        
        <div class="auth-card">
            @Body
        </div>
        
        <p class="auth-footer">© 2026 NodeSync. Electronics Production Facility</p>
    </div>
</div>

<style>
    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        font-family: 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    }

    .auth-background {
        position: fixed;
        inset: 0;
        z-index: 0;
    }

    #interactive-bg {
        display: block;
        width: 100%;
        height: 100%;
    }

    .auth-container {
        position: relative;
        width: 100%;
        max-width: 320px;
        padding: 0.5rem 0.75rem 1.25rem;
        z-index: 1;
    }

    @@media (max-width: 768px) {
        .auth-container {
            padding: 0 0.75rem 1rem;
        }
    }

    .auth-brand {
        text-align: center;
        margin-top: -1.5rem;
        margin-bottom: 1.25rem;
    }

    @@media (max-width: 768px) {
        .auth-brand {
            margin-top: -10rem;
            margin-bottom: 0.5rem;
        }
    }

    .brand-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.75rem;
    }

    @@media (max-width: 768px) {
        .brand-icon {
            margin-bottom: 1rem;
        }
    }

    .brand-icon img {
        width: 70px;
        height: 70px;
        object-fit: contain;
        filter: drop-shadow(0 0 12px rgba(255, 255, 255, 1)) drop-shadow(0 0 4px rgba(255, 255, 255, 0.8));
    }

    @@keyframes pulse-glow {
        0%, 100% { box-shadow: 0 20px 40px rgba(124, 58, 237, 0.4); }
        50% { box-shadow: 0 25px 50px rgba(124, 58, 237, 0.6); }
    }

    .brand-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: #1e1b4b;
        margin: 0 0 0.25rem 0;
        line-height: 1.2;
        letter-spacing: -0.5px;
        text-shadow: 0 0 15px rgba(255, 255, 255, 1), 0 0 5px rgba(255, 255, 255, 0.8);
    }

    .brand-subtitle {
        color: #4b5563;
        font-size: 0.75rem;
        margin: 0 0 0;
        line-height: 1.2;
        text-shadow: 0 0 10px rgba(255, 255, 255, 1), 0 0 3px rgba(255, 255, 255, 0.8);
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 16px;
        padding: 1.25rem;
        box-shadow: 
            0 25px 50px -12px rgba(0, 0, 0, 0.25),
            0 0 0 1px rgba(255, 255, 255, 0.1);
    }

    .auth-footer {
        text-align: center;
        color: #4b5563;
        font-size: 0.9rem;
        font-weight: 600;
        margin-top: 1.25rem;
        text-shadow: 0 0 10px rgba(255, 255, 255, 1), 0 0 4px rgba(255, 255, 255, 0.8);
        opacity: 0.95;
    }

    @@media (max-width: 768px) {
        .auth-footer {
            margin-top: 0.5rem;
        }
    }
</style>


