@using Microsoft.AspNetCore.Identity
@using production_system.Data

@inject SignInManager<ApplicationUser> SignInManager

<div class="manage-nav card">
    <div class="card-body p-2">
        <nav class="manage-nav-list">
            <NavLink class="manage-nav-item" href="Account/Manage" Match="NavLinkMatch.All">
                <i class="bi bi-person"></i>
                <span>Profile</span>
            </NavLink>
            <NavLink class="manage-nav-item" href="Account/Manage/ChangePassword">
                <i class="bi bi-shield-lock"></i>
                <span>Password</span>
            </NavLink>
            @if (hasExternalLogins)
            {
                <NavLink class="manage-nav-item" href="Account/Manage/ExternalLogins">
                    <i class="bi bi-link-45deg"></i>
                    <span>External Logins</span>
                </NavLink>
            }
            <NavLink class="manage-nav-item" href="Account/Manage/TwoFactorAuthentication">
                <i class="bi bi-phone"></i>
                <span>Two-Factor Auth</span>
            </NavLink>
            <NavLink class="manage-nav-item" href="Account/Manage/PersonalData">
                <i class="bi bi-database"></i>
                <span>Personal Data</span>
            </NavLink>
        </nav>
    </div>
</div>

<style>
    .manage-nav {
        position: sticky;
        top: 4rem;
    }

    .manage-nav-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .manage-nav-item {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        padding: 0.6rem 0.75rem;
        border-radius: 0.375rem;
        color: var(--ns-text-secondary);
        text-decoration: none;
        font-size: 0.8125rem;
        font-weight: 500;
        transition: all 0.12s ease;
    }

    .manage-nav-item:hover {
        background: #f6f7f8;
        color: var(--ns-text-dark);
        text-decoration: none;
    }

    .manage-nav-item.active {
        background: rgba(143, 0, 255, 0.08);
        color: var(--ns-primary);
        font-weight: 600;
    }

    .manage-nav-item .bi {
        font-size: 1rem;
        opacity: 0.7;
        width: 1.25rem;
        text-align: center;
        flex-shrink: 0;
    }

    .manage-nav-item.active .bi {
        opacity: 1;
    }
</style>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}

