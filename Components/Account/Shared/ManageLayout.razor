@inherits LayoutComponentBase
@layout production_system.Components.Layout.MainLayout

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using production_system.Data

@inject AuthenticationStateProvider AuthState
@inject IServiceProvider ServiceProvider
@inject NavigationManager NavManager

<div class="manage-account-container">
    <div class="manage-header mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="manage-header-icon">
                <i class="bi bi-gear"></i>
            </div>
            <div>
                <h1 class="h3 mb-0 fw-bold">Account Settings</h1>
                <p class="text-muted mb-0 small">Manage your profile, security, and preferences.</p>
            </div>
        </div>
    </div>

    <div class="row g-4 position-relative">
        <div class="col-lg-3">
            <ManageNavMenu />
        </div>
        <div class="col-lg-9 position-relative">
            @if (Show2FaOverlay)
            {
                <div class="alert alert-warning border-0 shadow-sm mb-4 d-flex align-items-center" style="border-left: 4px solid #ffc107 !important; border-radius: 8px;">
                    <i class="bi bi-shield-lock-fill fs-4 text-warning me-3"></i>
                    <div>
                        <h6 class="fw-bold mb-0 text-dark">Security Lock Active</h6>
                        <span class="small text-muted">You must activate Two-Factor Authentication first to be able to see and modify your account settings.</span>
                    </div>
                </div>

                <div class="position-absolute w-100 h-100 rounded-3" 
                     style="z-index: 100; cursor: not-allowed; top: 0; left: 0;" 
                     data-bs-toggle="modal" data-bs-target="#twoFaModal"></div>
            }
            <div class="manage-content-area" style="@(Show2FaOverlay ? "filter: blur(8px) grayscale(1); opacity: 0.2; pointer-events: none; user-select: none;" : "")">
                @Body
            </div>
        </div>
    </div>
</div>

@if (Show2FaOverlay)
{
    <div class="modal fade" id="twoFaModal" tabindex="-1" aria-labelledby="twoFaModalLabel" aria-hidden="true" style="z-index: 1050;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
                <div class="modal-header border-0 pb-0 pt-4 px-4">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <div class="mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle" style="width: 80px; height: 80px;">
                            <i class="bi bi-shield-lock-fill text-primary" style="font-size: 2.5rem;"></i>
                        </div>
                    </div>
                    <h4 class="fw-bold mb-3" id="twoFaModalLabel">2FA Registration Required</h4>
                    <p class="text-muted mb-4">
                        For your security, you must set up Two-Factor Authentication before you can modify your profile, change passwords, or access personal data.
                    </p>
                    <div class="d-grid gap-2">
                        <a href="Account/Manage/EnableAuthenticator" class="btn btn-primary py-2 fw-bold">
                            <i class="bi bi-qr-code-scan me-2"></i> Register 2FA Now
                        </a>
                        <button type="button" class="btn btn-light py-2 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .manage-account-container {
        max-width: 1000px;
    }

    .manage-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(143, 0, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ns-primary);
        font-size: 1.25rem;
    }

    .manage-content-area {
        min-height: 300px;
        transition: filter 0.3s ease, opacity 0.3s ease;
    }
</style>

@code {
    private bool is2faEnabled = true;
    private bool Show2FaOverlay => !is2faEnabled && !IsSecurityPage();

    protected override async Task OnInitializedAsync()
    {
        await LoadUserStatus();
    }

    private async Task LoadUserStatus()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            using var scope = ServiceProvider.CreateAsyncScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            
            var appUser = await userManager.GetUserAsync(user);
            if (appUser != null)
            {
                is2faEnabled = await userManager.GetTwoFactorEnabledAsync(appUser);
            }
        }
    }

    private bool IsSecurityPage()
    {
        var currentUri = NavManager.Uri.ToLowerInvariant();
        return currentUri.Contains("/enableauthenticator") || 
               currentUri.Contains("/twofactorauthentication") ||
               currentUri.Contains("/generaterecoverycodes") ||
               currentUri.Contains("/disable2fa") ||
               currentUri.Contains("/resetauthenticator");
    }
}

