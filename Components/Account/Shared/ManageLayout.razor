@inherits LayoutComponentBase
@layout production_system.Components.Layout.MainLayout

<div class="manage-account-container">
    <div class="manage-header mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="manage-header-icon">
                <i class="bi bi-gear"></i>
            </div>
            <div>
                <h1 class="h3 mb-0 fw-bold">Account Settings</h1>
                <p class="text-muted mb-0 small">Manage your profile, security, and preferences.</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-3">
            <ManageNavMenu />
        </div>
        <div class="col-lg-9">
            <div class="manage-content-area">
                @Body
            </div>
        </div>
    </div>
</div>

<style>
    .manage-account-container {
        max-width: 1000px;
    }

    .manage-header-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(143, 0, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ns-primary);
        font-size: 1.25rem;
    }

    .manage-content-area {
        min-height: 300px;
    }
</style>

